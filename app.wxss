/** app.wxss **/
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

button::after {
  border: none;
}

.page {
  min-height: 100vh;
  padding: 0;
  background: linear-gradient(180deg, #f1e5d4 0%, #f6f1ea 260rpx, #f8f4ee 100%);
}

.theme-page {
  position: relative;
  min-height: 100vh;
  background: linear-gradient(180deg, #f1e5d4 0%, #f6f1ea 260rpx, #f8f4ee 100%);
  overflow: hidden;
}

.theme-ambient {
  position: absolute;
  border-radius: 999rpx;
  pointer-events: none;
}

.theme-ambient--top {
  width: 420rpx;
  height: 420rpx;
  top: -140rpx;
  right: -120rpx;
  background: rgba(196, 111, 72, 0.18);
  box-shadow: 0 0 140rpx 32rpx rgba(196, 111, 72, 0.08);
}

.theme-ambient--side {
  width: 320rpx;
  height: 320rpx;
  top: 720rpx;
  left: -140rpx;
  background: rgba(41, 83, 72, 0.1);
  box-shadow: 0 0 120rpx 24rpx rgba(41, 83, 72, 0.06);
}

.theme-shell {
  position: relative;
  z-index: 1;
  padding: 28rpx 24rpx 170rpx;
  box-sizing: border-box;
}

.theme-shell--tab {
  padding-bottom: 220rpx;
}

.theme-shell--detail {
  padding-bottom: 190rpx;
}

.theme-hero-card {
  padding: 36rpx 28rpx;
  border-radius: 36rpx;
  background: linear-gradient(145deg, #1f3b34 0%, #152621 100%);
  box-shadow: 0 22rpx 48rpx rgba(24, 39, 34, 0.18);
  color: #fff6eb;
  animation: rise-in 0.5s ease both;
}

.theme-kicker {
  display: block;
  color: rgba(255, 244, 230, 0.72);
  font-size: 22rpx;
  letter-spacing: 4rpx;
}

.theme-hero-title {
  display: block;
  margin-top: 14rpx;
  font-size: 44rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #fff7ef;
}

.theme-hero-desc {
  display: block;
  margin-top: 12rpx;
  color: rgba(255, 244, 230, 0.78);
  font-size: 26rpx;
  line-height: 1.6;
}

.theme-count-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 88rpx;
  height: 88rpx;
  padding: 0 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 244, 230, 0.1);
  color: #fff6eb;
  font-size: 30rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.theme-count-badge--warm {
  background: #efe0cf;
  color: #8d5838;
}

.theme-status-pill {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 244, 230, 0.12);
  color: rgba(255, 244, 230, 0.82);
  font-size: 22rpx;
  font-weight: 600;
}

.theme-surface,
.card {
  margin-top: 22rpx;
  padding: 28rpx 24rpx;
  border-radius: 32rpx;
  background: #fffdf9;
  box-shadow: 0 18rpx 36rpx rgba(77, 61, 42, 0.08);
  box-sizing: border-box;
}

.card {
  margin-bottom: 20rpx;
}

.theme-section-title {
  display: block;
  color: #21342d;
  font-size: 34rpx;
  font-weight: 700;
}

.theme-section-desc {
  display: block;
  margin-top: 10rpx;
  color: #7d7063;
  font-size: 24rpx;
  line-height: 1.6;
}

.theme-inline-title {
  color: #9b6847;
  font-size: 22rpx;
  letter-spacing: 4rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #d57a4f 0%, #b85e3a 100%);
  color: #fff8f2;
  border: none;
  border-radius: 999rpx;
  padding: 22rpx 40rpx;
  font-size: 32rpx;
  line-height: 1.4;
  font-weight: 700;
  box-shadow: 0 16rpx 26rpx rgba(184, 94, 58, 0.24);
}

.btn-secondary {
  background: #f3ebe2;
  color: #5e544b;
  border: 2rpx solid rgba(154, 103, 69, 0.14);
  border-radius: 999rpx;
  padding: 22rpx 40rpx;
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 600;
}

.text-primary {
  color: #1f3b34;
}

.text-secondary {
  color: #6f655d;
}

.text-muted {
  color: #9c8f82;
}

.theme-chip,
.tag {
  display: inline-flex;
  align-items: center;
  margin-right: 10rpx;
  margin-bottom: 10rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f4ede5;
  color: #5d534a;
  font-size: 22rpx;
}

.tag.active,
.theme-chip--active {
  background: #24453d;
  color: #fff5ea;
}

.flex {
  display: flex;
}

.flex-column {
  flex-direction: column;
}

.flex-center {
  justify-content: center;
  align-items: center;
}

.flex-between {
  justify-content: space-between;
  align-items: center;
}

.flex-wrap {
  flex-wrap: wrap;
}

.text-center {
  text-align: center;
}

.mb-10 {
  margin-bottom: 10rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.mb-30 {
  margin-bottom: 30rpx;
}

.mt-10 {
  margin-top: 10rpx;
}

.mt-20 {
  margin-top: 20rpx;
}

.mt-30 {
  margin-top: 30rpx;
}

.p-20 {
  padding: 20rpx;
}

.p-30 {
  padding: 30rpx;
}

.loading,
.theme-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 70rpx 20rpx;
}

.loading-icon,
.theme-loading-icon {
  width: 78rpx;
  height: 78rpx;
  border: 6rpx solid rgba(184, 94, 58, 0.14);
  border-top-color: #b85e3a;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}

.loading-text,
.theme-loading-text {
  margin-top: 18rpx;
  color: #6e645a;
  font-size: 26rpx;
}

.theme-empty,
.empty-state {
  margin-top: 22rpx;
  padding: 72rpx 36rpx;
  border-radius: 32rpx;
  background: #fffdf9;
  box-shadow: 0 18rpx 36rpx rgba(77, 61, 42, 0.08);
  text-align: center;
  box-sizing: border-box;
}

.theme-empty-icon,
.empty-icon {
  font-size: 92rpx;
}

.theme-empty-title,
.empty-title {
  display: block;
  margin-top: 24rpx;
  color: #22342d;
  font-size: 34rpx;
  font-weight: 700;
}

.theme-empty-desc,
.empty-desc {
  display: block;
  margin-top: 14rpx;
  color: #7c7064;
  font-size: 26rpx;
  line-height: 1.6;
}

.input-group,
.picker-group {
  margin-bottom: 30rpx;
}

.input-label,
.picker-label {
  font-size: 28rpx;
  color: #3f433d;
  margin-bottom: 10rpx;
  font-weight: 600;
}

.input-field,
.picker-field {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid rgba(154, 103, 69, 0.14);
  border-radius: 18rpx;
  font-size: 28rpx;
  background: #f8f1e8;
  box-sizing: border-box;
}

.picker-field {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.input-field:focus {
  border-color: #b85e3a;
  background: #fffdf8;
}

.picker-arrow {
  color: #9b8f82;
  font-size: 24rpx;
}

.nutrition-grid {
  display: flex;
  flex-wrap: wrap;
  margin-top: 18rpx;
  margin-right: -12rpx;
}

.nutrition-item {
  width: calc(50% - 12rpx);
  margin: 0 12rpx 12rpx 0;
  padding: 22rpx 16rpx;
  border-radius: 22rpx;
  background: #f7efe5;
  text-align: center;
  box-sizing: border-box;
}

.nutrition-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f3b34;
}

.nutrition-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #766b61;
}

.step-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.step-number {
  width: 60rpx;
  height: 60rpx;
  margin-right: 20rpx;
  border-radius: 50%;
  background: #24453d;
  color: #fff7ef;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.step-content {
  flex: 1;
  color: #3f403d;
  font-size: 28rpx;
  line-height: 1.7;
}

.ingredient-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(154, 103, 69, 0.08);
}

.ingredient-item:last-child {
  border-bottom: none;
}

.ingredient-name {
  font-size: 28rpx;
  color: #313533;
}

.ingredient-amount {
  font-size: 28rpx;
  color: #6c655d;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

@keyframes rise-in {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}
