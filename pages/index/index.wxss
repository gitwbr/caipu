.page {
  position: relative;
  min-height: 100vh;
  padding-bottom: 220rpx;
  background: linear-gradient(180deg, #f1e5d4 0%, #f6f1ea 280rpx, #f8f4ee 100%);
  overflow: hidden;
}

.generate-sticky-bar {
  position: fixed;
  top: calc(env(safe-area-inset-top) + 18rpx);
  left: 24rpx;
  right: 24rpx;
  z-index: 20;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 28rpx;
  background: rgba(255, 253, 249, 0.94);
  border: 1rpx solid rgba(154, 103, 69, 0.08);
  box-shadow: 0 18rpx 36rpx rgba(77, 61, 42, 0.14);
  backdrop-filter: blur(16rpx);
  box-sizing: border-box;
}

.generate-sticky-copy {
  flex: 1;
  min-width: 0;
}

.generate-sticky-kicker {
  display: block;
  color: #9a6745;
  font-size: 20rpx;
  letter-spacing: 4rpx;
}

.generate-sticky-summary {
  display: block;
  margin-top: 8rpx;
  color: #243730;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
}

.generate-sticky-button {
  min-width: 220rpx;
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #d57a4f 0%, #b85e3a 100%);
  color: #fffaf6;
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 700;
  box-shadow: 0 14rpx 24rpx rgba(184, 94, 58, 0.2);
}

.generate-sticky-button::after {
  border: none;
}

.selection-sticky-bar {
  position: fixed;
  top: calc(env(safe-area-inset-top) + 124rpx);
  left: 24rpx;
  right: 24rpx;
  z-index: 19;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 12rpx;
  padding: 14rpx 16rpx 16rpx;
  border-radius: 26rpx;
  background: rgba(255, 248, 240, 0.96);
  border: 1rpx solid rgba(154, 103, 69, 0.08);
  box-shadow: 0 14rpx 26rpx rgba(77, 61, 42, 0.1);
  backdrop-filter: blur(16rpx);
  box-sizing: border-box;
}

.selection-sticky-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.selection-sticky-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.selection-sticky-count {
  width: 44rpx;
  height: 44rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #24453d;
  color: #fff7ef;
  font-size: 22rpx;
  font-weight: 700;
}

.selection-sticky-title {
  color: #6d5d51;
  font-size: 22rpx;
  font-weight: 700;
}

.selection-sticky-wrap {
  width: 100%;
}

.selection-sticky-row {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-start;
  gap: 10rpx 10rpx;
}

.selection-sticky-chip {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 12rpx 10rpx 14rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  max-width: calc(50% - 5rpx);
  min-height: 48rpx;
}

.selection-sticky-chip-ingredient {
  background: #24453d;
  color: #fff7ef;
}

.selection-sticky-chip-meta {
  background: #fffdf9;
  color: #594d43;
  border: 1rpx solid rgba(154, 103, 69, 0.12);
}

.selection-sticky-prefix {
  margin-right: 6rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.selection-sticky-chip-ingredient .selection-sticky-prefix {
  color: rgba(255, 247, 239, 0.72);
}

.selection-sticky-chip-meta .selection-sticky-prefix {
  color: #b35f3a;
}

.selection-sticky-text {
  font-size: 22rpx;
  line-height: 1.2;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.selection-sticky-remove {
  width: 30rpx;
  height: 30rpx;
  margin-left: 10rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 700;
  flex-shrink: 0;
}

.selection-sticky-chip-ingredient .selection-sticky-remove {
  background: rgba(255, 247, 239, 0.16);
  color: #fff7ef;
}

.selection-sticky-chip-meta .selection-sticky-remove {
  background: rgba(154, 103, 69, 0.12);
  color: #8f5d3e;
}

.selection-sticky-clear {
  flex-shrink: 0;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(184, 94, 58, 0.08);
  color: #b45d39;
  font-size: 22rpx;
  font-weight: 700;
}

.ambient {
  position: absolute;
  border-radius: 999rpx;
  pointer-events: none;
}

.ambient-top {
  width: 460rpx;
  height: 460rpx;
  top: -140rpx;
  right: -140rpx;
  background: rgba(196, 111, 72, 0.2);
  box-shadow: 0 0 140rpx 40rpx rgba(196, 111, 72, 0.12);
}

.ambient-side {
  width: 360rpx;
  height: 360rpx;
  top: 760rpx;
  left: -160rpx;
  background: rgba(41, 83, 72, 0.12);
  box-shadow: 0 0 120rpx 30rpx rgba(41, 83, 72, 0.08);
}

.hero-shell,
.workspace {
  position: relative;
  z-index: 1;
  padding-left: 24rpx;
  padding-right: 24rpx;
  box-sizing: border-box;
}

.hero-shell {
  padding-top: 156rpx;
}

.hero-shell--with-selection {
  padding-top: 366rpx;
}

.hero-card {
  overflow: hidden;
  padding: 40rpx 30rpx 34rpx;
  border-radius: 40rpx;
  background: linear-gradient(145deg, #1f3b34 0%, #152621 100%);
  box-shadow: 0 26rpx 56rpx rgba(23, 39, 34, 0.18);
  animation: rise-in 0.55s ease both;
}

.hero-topline {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.hero-label {
  color: rgba(255, 244, 230, 0.76);
  font-size: 22rpx;
  letter-spacing: 4rpx;
}

.hero-status {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.hero-status-online {
  background: rgba(255, 244, 230, 0.16);
  color: #fff3e4;
}

.hero-status-offline {
  background: rgba(255, 244, 230, 0.12);
  color: rgba(255, 244, 230, 0.8);
}

.hero-copy {
  display: flex;
  flex-direction: column;
}

.hero-title {
  color: #fff4e6;
  font-size: 58rpx;
  line-height: 1.08;
  font-weight: 700;
}

.hero-subtitle {
  margin-top: 18rpx;
  color: rgba(255, 244, 230, 0.76);
  font-size: 28rpx;
  line-height: 1.6;
}

.hero-limit-card {
  margin-top: 30rpx;
  padding: 24rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 244, 230, 0.1);
}

.hero-limit-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.hero-limit-label {
  color: rgba(255, 244, 230, 0.68);
  font-size: 24rpx;
}

.hero-limit-value {
  color: #fff7ef;
  font-size: 48rpx;
  line-height: 1;
  font-weight: 700;
}

.hero-limit-value-muted {
  font-size: 34rpx;
  letter-spacing: 4rpx;
}

.hero-limit-tip {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 244, 230, 0.76);
  font-size: 24rpx;
}

.hero-stats {
  display: flex;
  margin-top: 24rpx;
}

.hero-stat {
  flex: 1;
  margin-right: 12rpx;
  padding: 18rpx 18rpx 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.08);
}

.hero-stat:last-child {
  margin-right: 0;
}

.hero-stat-label {
  display: block;
  color: rgba(255, 244, 230, 0.62);
  font-size: 22rpx;
}

.hero-stat-value {
  display: block;
  margin-top: 10rpx;
  color: #fff5e9;
  font-size: 34rpx;
  font-weight: 700;
}

.scene-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 28rpx;
}

.scene-title {
  color: #fff5e9;
  font-size: 28rpx;
  font-weight: 600;
}

.scene-desc {
  color: rgba(255, 244, 230, 0.66);
  font-size: 22rpx;
}

.scene-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 18rpx -8rpx 0;
}

.scene-card {
  width: calc(50% - 16rpx);
  margin: 0 8rpx 16rpx;
  padding: 20rpx;
  border-radius: 26rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 244, 230, 0.1);
}

.scene-card-active {
  background: linear-gradient(180deg, rgba(231, 169, 124, 0.22) 0%, rgba(255, 255, 255, 0.12) 100%);
  border-color: rgba(255, 233, 211, 0.4);
  box-shadow: 0 12rpx 20rpx rgba(13, 23, 20, 0.12);
}

.scene-kicker {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border-radius: 14rpx;
  background: rgba(255, 244, 230, 0.12);
  color: #fff1df;
  font-size: 22rpx;
  font-weight: 700;
}

.scene-name {
  display: block;
  margin-top: 16rpx;
  color: #fff6eb;
  font-size: 28rpx;
  font-weight: 600;
}

.scene-note {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 244, 230, 0.72);
  font-size: 22rpx;
  line-height: 1.5;
}

.workspace {
  margin-top: 28rpx;
  animation: rise-in 0.72s ease both;
}

.section-intro {
  padding: 0 6rpx 8rpx;
}

.section-kicker {
  color: #9a6745;
  font-size: 22rpx;
  letter-spacing: 4rpx;
}

.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 14rpx;
}

.section-title {
  color: #1f302a;
  font-size: 42rpx;
  font-weight: 700;
}

.selection-count {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #efe0cf;
  color: #915a39;
  font-size: 22rpx;
  font-weight: 600;
}

.section-desc {
  display: block;
  margin-top: 12rpx;
  color: #766a5f;
  font-size: 26rpx;
  line-height: 1.6;
}

.mode-switch-card {
  margin-top: 24rpx;
  padding: 24rpx 22rpx;
  border-radius: 28rpx;
  background: linear-gradient(145deg, #fff8ef 0%, #f4e8d9 100%);
  border: 1rpx solid rgba(154, 103, 69, 0.12);
  box-shadow: 0 14rpx 30rpx rgba(97, 79, 55, 0.08);
}

.mode-switch-copy {
  display: flex;
  flex-direction: column;
}

.mode-switch-kicker {
  color: #9b6847;
  font-size: 22rpx;
  letter-spacing: 4rpx;
}

.mode-switch-desc {
  margin-top: 10rpx;
  color: #695f55;
  font-size: 24rpx;
  line-height: 1.6;
}

.mode-switch-row {
  display: flex;
  justify-content: space-between;
  margin-top: 18rpx;
}

.mode-pill {
  display: flex;
  flex-direction: column;
  width: calc(50% - 8rpx);
  min-height: 130rpx;
  padding: 20rpx 18rpx;
  border-radius: 24rpx;
  box-sizing: border-box;
  border: 2rpx solid rgba(67, 79, 67, 0.08);
  box-shadow: 0 10rpx 20rpx rgba(83, 70, 51, 0.05);
}

.mode-pill-home {
  background: rgba(255, 255, 255, 0.86);
}

.mode-pill-creative {
  background: rgba(255, 245, 238, 0.92);
}

.mode-pill-active {
  color: #fff7ef;
  border-color: transparent;
}

.mode-pill-home.mode-pill-active {
  background: linear-gradient(145deg, #24453d 0%, #1a302a 100%);
  box-shadow: 0 16rpx 28rpx rgba(36, 69, 61, 0.18);
}

.mode-pill-creative.mode-pill-active {
  background: linear-gradient(145deg, #b7603b 0%, #8d4326 100%);
  box-shadow: 0 16rpx 28rpx rgba(183, 96, 59, 0.22);
}

.mode-pill-label {
  color: #21332d;
  font-size: 30rpx;
  font-weight: 700;
}

.mode-pill-desc {
  margin-top: 10rpx;
  color: #6d655c;
  font-size: 22rpx;
  line-height: 1.5;
}

.mode-pill-active .mode-pill-label,
.mode-pill-active .mode-pill-desc {
  color: #fff7ef;
}

.tab-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 24rpx -8rpx 0;
}

.tab-card {
  display: flex;
  flex-direction: column;
  width: calc(50% - 16rpx);
  min-height: 184rpx;
  margin: 0 8rpx 16rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  box-sizing: border-box;
  background: #fffdf9;
  border: 2rpx solid rgba(57, 49, 38, 0.06);
  box-shadow: 0 12rpx 24rpx rgba(77, 61, 42, 0.08);
}

.tab-card-active {
  background: linear-gradient(145deg, #b85e3a 0%, #8f4426 100%);
  border-color: transparent;
  box-shadow: 0 18rpx 30rpx rgba(184, 94, 58, 0.24);
}

.tab-order {
  display: block;
  color: #a28875;
  font-size: 22rpx;
  letter-spacing: 3rpx;
}

.tab-name {
  display: block;
  margin-top: 12rpx;
  color: #22352f;
  font-size: 30rpx;
  font-weight: 700;
}

.tab-desc {
  display: block;
  margin-top: 10rpx;
  color: #766d63;
  font-size: 24rpx;
  line-height: 1.5;
}

.tab-card-active .tab-order,
.tab-card-active .tab-desc {
  color: rgba(255, 243, 233, 0.76);
}

.tab-card-active .tab-name {
  color: #fff7ef;
}

.selector-card,
.selection-board,
.cta-card {
  border-radius: 36rpx;
  box-sizing: border-box;
}

.selector-card {
  margin-top: 8rpx;
  padding: 32rpx 26rpx;
  background: #fffdf9;
  box-shadow: 0 18rpx 36rpx rgba(77, 61, 42, 0.08);
  animation: rise-in 0.86s ease both;
}

.selector-card-header {
  display: flex;
  flex-direction: column;
}

.selector-kicker {
  color: #9c6847;
  font-size: 22rpx;
  letter-spacing: 4rpx;
}

.selector-title {
  margin-top: 12rpx;
  color: #21332d;
  font-size: 38rpx;
  font-weight: 700;
}

.selector-note {
  margin-top: 10rpx;
  color: #7e7266;
  font-size: 24rpx;
  line-height: 1.6;
}

.selector-status-card,
.selector-warning-card {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
}

.selector-status-card {
  background: #f6efe6;
  border: 1rpx solid rgba(36, 69, 61, 0.08);
}

.selector-warning-card {
  background: rgba(184, 94, 58, 0.08);
  border: 1rpx solid rgba(184, 94, 58, 0.18);
}

.selector-status-label,
.selector-warning-label {
  display: block;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
}

.selector-status-label {
  color: #8e6647;
}

.selector-warning-label {
  color: #b35d39;
}

.selector-status-text,
.selector-warning-text {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
}

.selector-status-text {
  color: #5f635d;
}

.selector-warning-text {
  color: #9b5736;
}

.selector-panel {
  margin-top: 28rpx;
}

.ingredient-tabs {
  width: 100%;
  white-space: nowrap;
}

.ingredient-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: #f3e8da;
  color: #6f665d;
  font-size: 24rpx;
  font-weight: 600;
}

.ingredient-tab-active {
  background: #24453d;
  color: #fff5ea;
  box-shadow: 0 12rpx 18rpx rgba(36, 69, 61, 0.14);
}

.category-block {
  margin-top: 28rpx;
  padding: 26rpx 22rpx 10rpx;
  border-radius: 30rpx;
  background: #f7efe5;
  border: 1rpx solid rgba(154, 103, 69, 0.08);
}

.category-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.category-title {
  color: #1f342d;
  font-size: 30rpx;
  font-weight: 700;
}

.category-count {
  color: #9b6948;
  font-size: 22rpx;
}

.chip-grid,
.summary-chip-grid,
.add-custom-actions {
  display: flex;
  flex-wrap: wrap;
}

.select-chip,
.add-custom-chip,
.summary-chip {
  box-sizing: border-box;
}

.select-chip,
.add-custom-chip {
  margin: 0 12rpx 14rpx 0;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  line-height: 1.2;
}

.select-chip {
  background: #fff;
  color: #4d5348;
  border: 2rpx solid rgba(67, 79, 67, 0.08);
  box-shadow: 0 8rpx 18rpx rgba(83, 70, 51, 0.06);
}

.select-chip-meta {
  background: #f8f1e8;
}

.select-chip-active {
  background: linear-gradient(145deg, #24453d 0%, #1a312b 100%);
  color: #fff6eb;
  border-color: transparent;
  box-shadow: 0 14rpx 22rpx rgba(31, 59, 52, 0.2);
}

.add-custom-chip {
  background: transparent;
  color: #b25d39;
  border: 2rpx dashed rgba(178, 93, 57, 0.55);
}

.selection-board {
  margin-top: 26rpx;
  padding: 28rpx 24rpx;
  background: linear-gradient(145deg, #fff7ec 0%, #f7eadc 100%);
  box-shadow: 0 16rpx 30rpx rgba(151, 107, 71, 0.1);
  animation: rise-in 0.94s ease both;
}

.selection-board-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 18rpx;
}

.selection-board-copy {
  display: flex;
  flex-direction: column;
}

.selection-board-kicker {
  color: #9a6745;
  font-size: 22rpx;
  letter-spacing: 4rpx;
}

.selection-board-title {
  margin-top: 10rpx;
  color: #21342d;
  font-size: 30rpx;
  font-weight: 700;
}

.selection-reset {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(184, 94, 58, 0.08);
  color: #b45d39;
  font-size: 22rpx;
  font-weight: 600;
}

.summary-chip {
  display: flex;
  align-items: center;
  margin: 0 12rpx 12rpx 0;
  padding: 12rpx 14rpx 12rpx 18rpx;
  border-radius: 22rpx;
}

.summary-chip-ingredient {
  background: #204038;
  color: #fff6eb;
}

.summary-chip-meta {
  background: #fff;
  color: #594d43;
  border: 1rpx solid rgba(154, 103, 69, 0.12);
}

.summary-chip-prefix {
  margin-right: 8rpx;
  color: #b35f3a;
  font-size: 22rpx;
  font-weight: 700;
}

.summary-chip-ingredient .summary-chip-prefix {
  color: rgba(255, 246, 235, 0.72);
}

.summary-chip-text {
  font-size: 24rpx;
}

.summary-chip-remove {
  width: 34rpx;
  height: 34rpx;
  margin-left: 12rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(154, 103, 69, 0.12);
  color: #8f5d3e;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 700;
  flex-shrink: 0;
}

.summary-chip-ingredient .summary-chip-remove {
  background: rgba(255, 246, 235, 0.18);
  color: #fff6eb;
}

.cta-card {
  margin-top: 26rpx;
  padding: 32rpx 28rpx;
  background: linear-gradient(145deg, #2a473f 0%, #182a25 100%);
  box-shadow: 0 22rpx 44rpx rgba(24, 42, 37, 0.18);
  animation: rise-in 1s ease both;
}

.cta-copy {
  display: flex;
  flex-direction: column;
}

.cta-kicker {
  color: rgba(255, 244, 230, 0.66);
  font-size: 22rpx;
  letter-spacing: 4rpx;
}

.cta-mode-chip {
  align-self: flex-start;
  margin-top: 14rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.cta-mode-chip-home {
  background: rgba(255, 246, 235, 0.12);
  color: #fff1e4;
  border: 1rpx solid rgba(255, 246, 235, 0.18);
}

.cta-mode-chip-creative {
  background: rgba(255, 198, 154, 0.16);
  color: #ffd8bd;
  border: 1rpx solid rgba(255, 198, 154, 0.24);
}

.cta-title {
  margin-top: 12rpx;
  color: #fff6eb;
  font-size: 38rpx;
  line-height: 1.3;
  font-weight: 700;
}

.cta-desc {
  margin-top: 12rpx;
  color: rgba(255, 244, 230, 0.76);
  font-size: 26rpx;
  line-height: 1.6;
}

.add-custom-cancel::after,
.add-custom-confirm::after {
  border: none;
}

.loading-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 24rpx;
  padding: 18rpx 0 4rpx;
}

.loading-icon {
  width: 72rpx;
  height: 72rpx;
  border: 6rpx solid rgba(184, 94, 58, 0.14);
  border-top-color: #b85e3a;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}

.loading-text {
  margin-top: 18rpx;
  color: #6d645a;
  font-size: 26rpx;
}

.add-custom-modal {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 99;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  box-sizing: border-box;
  background: rgba(26, 20, 14, 0.36);
}

.add-custom-modal-content {
  width: 100%;
  padding: 36rpx 28rpx 30rpx;
  border-radius: 32rpx;
  box-sizing: border-box;
  background: #fffdf8;
  box-shadow: 0 22rpx 48rpx rgba(24, 18, 13, 0.16);
}

.add-custom-modal-title {
  color: #22342d;
  font-size: 34rpx;
  font-weight: 700;
}

.add-custom-modal-desc {
  display: block;
  margin-top: 12rpx;
  color: #7c7064;
  font-size: 25rpx;
  line-height: 1.6;
}

.add-custom-input {
  width: 100%;
  height: 88rpx;
  margin-top: 24rpx;
  margin-bottom: 26rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  box-sizing: border-box;
  background: #f8f1e8;
  border: 2rpx solid rgba(154, 103, 69, 0.14);
  font-size: 28rpx;
}

.add-custom-actions {
  justify-content: space-between;
}

.add-custom-cancel,
.add-custom-confirm {
  width: calc(50% - 8rpx);
  padding: 20rpx 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 600;
}

.add-custom-cancel {
  background: #f3ebe2;
  color: #6c645c;
}

.add-custom-confirm {
  background: linear-gradient(135deg, #d57a4f 0%, #b85e3a 100%);
  color: #fff8f2;
}

@keyframes rise-in {
  from {
    opacity: 0;
    transform: translateY(28rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
