<view class="page">
  <view class="ambient ambient-top"></view>
  <view class="ambient ambient-side"></view>

  <view class="generate-sticky-bar">
    <view class="generate-sticky-copy">
      <text class="generate-sticky-kicker">GENERATE</text>
      <text class="generate-sticky-summary">{{stickyGenerateSummaryText}}</text>
    </view>
    <button class="generate-sticky-button" bindtap="onGenerateRecipe" disabled="{{isLoading}}">
      <text wx:if="{{isLoading}}">生成中...</text>
      <text wx:elif="{{isLoggedIn}}">生成菜谱</text>
      <text wx:else>登录生成</text>
    </button>
  </view>

  <view class="selection-sticky-bar" wx:if="{{selectedSummaryItems.length > 0}}">
    <view class="selection-sticky-top">
      <view class="selection-sticky-head">
        <view class="selection-sticky-count">{{selectionCount}}</view>
        <text class="selection-sticky-title">已选主料与约束</text>
      </view>
      <view class="selection-sticky-clear" bindtap="onClearAllSelections">清空</view>
    </view>
    <view class="selection-sticky-wrap">
      <view class="selection-sticky-row">
        <block wx:for="{{selectedSummaryItems}}" wx:key="id">
          <view class="selection-sticky-chip {{item.kind === 'ingredient' ? 'selection-sticky-chip-ingredient' : 'selection-sticky-chip-meta'}}">
            <text class="selection-sticky-prefix" wx:if="{{item.prefix}}">{{item.prefix}}</text>
            <text class="selection-sticky-text">{{item.label}}</text>
            <view
              class="selection-sticky-remove"
              catchtap="onRemoveSummaryItem"
              data-remove-kind="{{item.removeKind}}"
              data-remove-field="{{item.removeField}}"
              data-remove-value="{{item.removeValue}}"
            >
              ×
            </view>
          </view>
        </block>
      </view>
    </view>
  </view>

  <view class="hero-shell {{selectedSummaryItems.length > 0 ? 'hero-shell--with-selection' : ''}}">
    <view class="hero-card">
      <view class="hero-topline">
        <text class="hero-label">KITCHEN NOTE</text>
        <view class="hero-status {{isLoggedIn ? 'hero-status-online' : 'hero-status-offline'}}">
          {{isLoggedIn ? '已登录' : '游客模式'}}
        </view>
      </view>

      <view class="hero-copy">
        <text class="hero-title">今天吃点什么？</text>
        <text class="hero-subtitle">从主料、口味到锅具设备，组合一份更真实、更能下锅的 AI 家常菜谱。</text>
      </view>

      <view class="hero-limit-card">
        <view class="hero-limit-main">
          <text class="hero-limit-label">{{isLoggedIn ? '今日可生成' : '登录后解锁额度与收藏'}}</text>
          <text class="hero-limit-value" wx:if="{{isLoggedIn && userLimits}}">{{remainingGenerationCount}}</text>
          <text class="hero-limit-value hero-limit-value-muted" wx:else>READY</text>
        </view>
        <text class="hero-limit-tip" wx:if="{{isLoggedIn && userLimits}}">
          收藏 {{userLimits.total_favorites_count}} / {{userLimits.total_favorites_limit}}
        </text>
        <text class="hero-limit-tip" wx:else>保存偏好、同步历史、随时继续做饭</text>
      </view>

      <view class="hero-stats">
        <view class="hero-stat">
          <text class="hero-stat-label">已选食材</text>
          <text class="hero-stat-value">{{selectedIngredientNames.length}}</text>
        </view>
        <view class="hero-stat">
          <text class="hero-stat-label">已加约束</text>
          <text class="hero-stat-value">{{selectedMetaCount}}</text>
        </view>
        <view class="hero-stat">
          <text class="hero-stat-label">已选设备</text>
          <text class="hero-stat-value">{{selectedKitchenEnvironmentNames.length}}</text>
        </view>
      </view>

      <view class="scene-header">
        <text class="scene-title">灵感捷径</text>
        <text class="scene-desc">先套一个氛围，再微调细节</text>
      </view>

      <view class="scene-grid">
        <block wx:for="{{quickScenes}}" wx:key="key">
          <view class="scene-card {{activePresetKey === item.key ? 'scene-card-active' : ''}}" bindtap="onApplyPreset" data-key="{{item.key}}">
            <text class="scene-kicker">{{item.kicker}}</text>
            <text class="scene-name">{{item.label}}</text>
            <text class="scene-note">{{item.desc}}</text>
          </view>
        </block>
      </view>
    </view>
  </view>

  <view class="workspace">
    <view class="section-intro">
      <text class="section-kicker">COOKBOOK BUILDER</text>
      <view class="section-title-row">
        <text class="section-title">定制今日菜谱</text>
        <view class="selection-count">{{selectionCount}} 项偏好</view>
      </view>
      <text class="section-desc">不需要一次想全。你先定主料和关键约束，剩下的维度会由 AI 按普通家庭厨房逻辑自动补全。</text>
    </view>

    <view class="tab-grid">
      <block wx:for="{{tabOptions}}" wx:key="key">
        <view class="tab-card {{activeTab === index ? 'tab-card-active' : ''}}" bindtap="onTabChange" data-index="{{index}}">
          <text class="tab-order">0{{index + 1}}</text>
          <text class="tab-name">{{item.label}}</text>
          <text class="tab-desc">{{item.desc}}</text>
        </view>
      </block>
    </view>

    <view class="selector-card">
      <view class="selector-card-header">
        <text class="selector-kicker">{{tabOptions[activeTab].eyebrow}}</text>
        <text class="selector-title">{{tabOptions[activeTab].panelTitle}}</text>
        <text class="selector-note">{{tabOptions[activeTab].note}}</text>
        <view class="selector-status-card" wx:if="{{autoFillSummaryText}}">
          <text class="selector-status-label">AUTO FILL</text>
          <text class="selector-status-text">{{autoFillSummaryText}}</text>
        </view>
        <view class="selector-warning-card" wx:if="{{methodKitchenConflictMessage}}">
          <text class="selector-warning-label">冲突提示</text>
          <text class="selector-warning-text">{{methodKitchenConflictMessage}}</text>
        </view>
      </view>

      <view class="selector-panel" wx:if="{{activeTab === 0}}">
        <scroll-view class="ingredient-tabs" scroll-x="true" enable-flex="true" show-scrollbar="false">
          <block wx:for="{{ingredientCategoryTabs}}" wx:key="index">
            <view class="ingredient-tab {{activeIngredientCategoryTab === index ? 'ingredient-tab-active' : ''}}" data-index="{{index}}" bindtap="onIngredientCategoryTabChange">
              {{item}}
            </view>
          </block>
        </scroll-view>

        <view class="category-block" wx:if="{{categorizedIngredients.length}}">
          <view class="category-head">
            <text class="category-title">{{categorizedIngredients[activeIngredientCategoryTab].categoryName}}</text>
            <text class="category-count">{{selectedIngredientNames.length}} 已选</text>
          </view>
          <view class="chip-grid">
            <block wx:for="{{categorizedIngredients[activeIngredientCategoryTab].ingredients}}" wx:key="name">
              <view class="select-chip {{item.selected ? 'select-chip-active' : ''}}" bindtap="onIngredientTagTap" data-category-index="{{activeIngredientCategoryTab}}" data-ingredient-index="{{index}}">
                {{item.name}}
              </view>
            </block>
            <view class="add-custom-chip" bindtap="onShowAddCustomInput" data-type="ingredient">+ 添加食材</view>
          </view>
        </view>
      </view>

      <view class="selector-panel" wx:if="{{activeTab === 1}}">
        <view class="chip-grid">
          <block wx:for="{{dishTypeNames}}" wx:key="index">
            <view class="select-chip select-chip-meta {{selectedDishTypeIndex === index ? 'select-chip-active' : ''}}" bindtap="onDishTypeTagTap" data-index="{{index}}">
              {{item}}
            </view>
          </block>
          <view class="add-custom-chip" bindtap="onShowAddCustomInput" data-type="dishType">+ 添加类型</view>
        </view>
      </view>

      <view class="selector-panel" wx:if="{{activeTab === 2}}">
        <view class="chip-grid">
          <block wx:for="{{typeNames}}" wx:key="index">
            <view class="select-chip select-chip-meta {{selectedTypeIndex === index ? 'select-chip-active' : ''}}" bindtap="onTypeTagTap" data-index="{{index}}">
              {{item}}
            </view>
          </block>
          <view class="add-custom-chip" bindtap="onShowAddCustomInput" data-type="type">+ 添加菜系</view>
        </view>
      </view>

      <view class="selector-panel" wx:if="{{activeTab === 3}}">
        <view class="chip-grid">
          <block wx:for="{{tasteNames}}" wx:key="index">
            <view class="select-chip select-chip-meta {{selectedTasteIndex === index ? 'select-chip-active' : ''}}" bindtap="onTasteTagTap" data-index="{{index}}">
              {{item}}
            </view>
          </block>
        </view>
      </view>

      <view class="selector-panel" wx:if="{{activeTab === 4}}">
        <view class="chip-grid">
          <block wx:for="{{methodNames}}" wx:key="index">
            <view class="select-chip select-chip-meta {{selectedMethodIndex === index ? 'select-chip-active' : ''}}" bindtap="onMethodTagTap" data-index="{{index}}">
              {{item}}
            </view>
          </block>
          <view class="add-custom-chip" bindtap="onShowAddCustomInput" data-type="method">+ 添加做法</view>
        </view>
      </view>

      <view class="selector-panel" wx:if="{{activeTab === 5}}">
        <view class="chip-grid">
          <block wx:for="{{kitchenEnvironmentOptions}}" wx:key="name">
            <view class="select-chip select-chip-meta {{item.selected ? 'select-chip-active' : ''}}" bindtap="onKitchenEnvironmentTagTap" data-index="{{index}}">
              {{item.name}}
            </view>
          </block>
        </view>
      </view>
    </view>

    <view class="cta-card">
      <view class="cta-copy">
        <text class="cta-kicker">AI COOK MODE</text>
        <text class="cta-title" wx:if="{{selectedIngredientNames.length > 0}}">你的食材组合已经准备好了</text>
        <text class="cta-title" wx:else>没选食材也能开始，AI 会按偏好补全更自然的主料组合</text>
        <text class="cta-desc" wx:if="{{isLoggedIn}}">生成后会进入菜谱详情，并自动记录到最近历史；营养会按每 100g 或每 100ml 自动兼容。</text>
        <text class="cta-desc" wx:else>登录后可以查看额度、收藏菜谱，并保留你的历史记录。</text>
      </view>
    </view>

    <view class="loading-panel" wx:if="{{isLoading}}">
      <view class="loading-icon"></view>
      <text class="loading-text">AI 正在整理口味搭配和步骤，请稍候...</text>
    </view>
  </view>

  <view wx:if="{{showAddCustomInput}}" class="add-custom-modal" bindtap="onAddCustomCancel">
    <view class="add-custom-modal-content" catchtap="onModalContentTap">
      <text class="add-custom-modal-title">{{customInputTitle}}</text>
      <text class="add-custom-modal-desc">把你今天特别想吃的内容加进候选列表。</text>
      <input class="add-custom-input" placeholder="{{customInputPlaceholder}}" value="{{addCustomValue}}" bindinput="onAddCustomInput" bindconfirm="onAddCustomConfirm" confirm-type="done" />
      <view class="add-custom-actions">
        <button class="add-custom-cancel" bindtap="onAddCustomCancel">取消</button>
        <button class="add-custom-confirm" bindtap="onAddCustomConfirm">添加</button>
      </view>
    </view>
  </view>
</view>
