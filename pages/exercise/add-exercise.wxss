.exercise-picker-page {
  min-height: 100vh;
}

.picker-hero-metrics {
  display: flex;
  gap: 12rpx;
  margin-top: 26rpx;
}

.picker-hero-metric {
  flex: 1;
  padding: 18rpx 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.08);
}

.picker-hero-label {
  display: block;
  color: rgba(255, 244, 230, 0.68);
  font-size: 22rpx;
}

.picker-hero-value {
  display: block;
  margin-top: 10rpx;
  color: #fff7ef;
  font-size: 30rpx;
  font-weight: 700;
}

.picker-list-card {
  margin-top: 22rpx;
  padding: 30rpx 24rpx;
  border-radius: 32rpx;
  background: #fffdf9;
  box-shadow: 0 18rpx 36rpx rgba(77, 61, 42, 0.08);
  box-sizing: border-box;
}

.picker-list-title {
  margin-top: 10rpx;
}

.list {
  margin-top: 22rpx;
}

.item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(154, 103, 69, 0.08);
}

.item:last-child {
  border-bottom: none;
}

.item-icon-wrap {
  width: 94rpx;
  height: 94rpx;
  padding: 6rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f7efe5 0%, #f1e7db 100%);
  box-sizing: border-box;
  flex-shrink: 0;
}

.icon {
  width: 100%;
  height: 100%;
  border-radius: 18rpx;
  background: #f7efe5;
}

.item-main {
  flex: 1;
  min-width: 0;
}

.title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.title {
  color: #22342d;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.3;
}

.method-chip {
  flex-shrink: 0;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: #f4ede5;
  color: #9b6847;
  font-size: 22rpx;
  white-space: nowrap;
}

.desc {
  margin-top: 8rpx;
  color: #7b7064;
  font-size: 24rpx;
  line-height: 1.55;
}

.item-arrow {
  margin-left: 4rpx;
  color: #b59682;
  font-size: 34rpx;
  line-height: 1;
}
