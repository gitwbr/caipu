.container {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #f1e5d4 0%, #f6f1ea 260rpx, #f8f4ee 100%);
}

.list {
  background: #fffdf9;
  border-radius: 32rpx;
  padding: 8rpx 0;
  box-shadow: 0 18rpx 36rpx rgba(77, 61, 42, 0.08);
}

.item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 26rpx 24rpx;
  border-bottom: 1rpx solid rgba(154, 103, 69, 0.08);
}

.item:last-child {
  border-bottom: none;
}

.icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: #f7efe5;
  flex-shrink: 0;
}

.item-main {
  flex: 1;
  min-width: 0;
}

.title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.title {
  color: #22342d;
  font-size: 31rpx;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.method-chip {
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: #f4ede5;
  color: #9b6847;
  font-size: 22rpx;
  white-space: nowrap;
}

.desc {
  margin-top: 8rpx;
  color: #7b7064;
  font-size: 24rpx;
  line-height: 1.5;
}
