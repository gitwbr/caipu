<view class="theme-page exercise-detail-page">
  <view class="theme-ambient theme-ambient--top"></view>
  <view class="theme-ambient theme-ambient--side"></view>

  <view class="theme-shell theme-shell--detail exercise-detail-shell">
    <view class="exercise-overview-card">
      <text class="theme-kicker">MOVE ENTRY</text>

      <view class="overview-top">
        <view class="overview-copy">
          <text class="theme-hero-title">{{typeName || '运动记录'}}</text>
          <text class="theme-hero-desc">{{methodLabel}}</text>
        </view>

        <view class="overview-kcal">
          <text class="overview-kcal-label">预计消耗</text>
          <text class="overview-kcal-value">{{calories_burned_kcal || 0}}</text>
          <text class="overview-kcal-unit">kcal</text>
        </view>
      </view>

      <view class="overview-grid">
        <view class="overview-item">
          <text class="overview-label">类型</text>
          <text class="overview-value">{{typeName}}</text>
        </view>
        <view class="overview-item">
          <text class="overview-label">方法</text>
          <text class="overview-value">{{methodLabel}}</text>
        </view>
        <view class="overview-item">
          <text class="overview-label">时长 (min)</text>
          <input class="overview-input" type="digit" value="{{duration_min}}" bindinput="onInput" data-key="duration_min" placeholder="请输入时长" />
        </view>
        <view class="overview-item">
          <text class="overview-label">体重 (kg)</text>
          <input class="overview-input" type="digit" value="{{weight_kg_at_time}}" bindinput="onInput" data-key="weight_kg_at_time" placeholder="未填则用个人资料体重" />
        </view>
      </view>
    </view>

    <view class="card form-card">
      <text class="theme-inline-title">TIME & PARAMS</text>
      <text class="theme-section-title utility-title">记录时间与参数</text>

      <view class="form-item">
        <picker mode="time" value="{{record_time}}" bindchange="onTimeChange">
          <view class="picker-content">
            <text class="picker-value">{{record_time}}</text>
            <text class="picker-arrow">></text>
          </view>
        </picker>
      </view>

      <view class="section-title">参数</view>
      <block wx:for="{{dynamicFields}}" wx:key="key">
        <view class="param-row">
          <text class="p-label">{{item.label}}</text>
          <block wx:if="{{item.type==='enum'}}">
            <picker range="{{item.options}}" range-key="label" value="{{item.index}}" data-key="{{item.key}}" bindchange="onEnumChange">
              <view class="picker-content picker-content-inline">
                <text class="picker-value">{{item.index !== undefined ? item.options[item.index].label : '请选择'}}</text>
                <text class="picker-arrow">></text>
              </view>
            </picker>
          </block>
          <block wx:else>
            <input class="p-input" type="digit" value="{{item.value}}" placeholder="{{item.placeholder}}" data-key="{{item.key}}" bindinput="onParamInput" />
          </block>
        </view>
      </block>

      <view class="bottom-hints" wx:if="{{bottomHintsText}}">
        <view class="bottom-hints-title">合理范围推荐</view>
        <view class="bottom-hints-text">{{bottomHintsText}}</view>
      </view>
    </view>

    <view class="card help-card" wx:if="{{isIntensityType}}">
      <text class="theme-inline-title">INTENSITY GUIDE</text>
      <text class="theme-section-title utility-title">参数说明</text>
      <text class="help-line">强度：选择低 / 中 / 高，对应不同 MET 估算；如果不确定，先选中等强度。</text>
      <text class="help-line">RPE：主观用力程度 1-10；填写 RPE 会清空强度，选择强度也会清空 RPE。</text>
    </view>

    <view class="actions">
      <button class="btn btn-secondary" bindtap="onCancel">取消</button>
      <button class="btn btn-primary" bindtap="onSave" disabled="{{saveDisabled}}">保存</button>
    </view>
  </view>
</view>
