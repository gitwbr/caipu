<view class="theme-page recipe-page">
  <view class="theme-ambient theme-ambient--top"></view>
  <view class="theme-ambient theme-ambient--side"></view>

  <view class="theme-shell theme-shell--detail recipe-shell {{(isFavorite || isLocalHistoryRecipe) ? 'recipe-shell--with-actions' : ''}}">
    <view class="recipe-hero">
      <text class="theme-kicker">AI RECIPE NOTE</text>
      <text class="theme-hero-title">{{recipe.name}}</text>
      <text class="theme-hero-desc">{{recipe.description}}</text>

      <view class="recipe-tags">
        <view class="recipe-hero-tag" wx:for="{{recipe.tags}}" wx:key="index">{{item}}</view>
      </view>

      <view class="recipe-toolbar">
        <view class="favorite-pill {{isFavorite ? 'favorite-pill-active' : ''}}" bindtap="toggleFavorite">
          <view class="favorite-pill-copy">
            <text class="favorite-pill-kicker">{{isFavorite ? 'FAVORITE SAVED' : 'SAVE THIS RECIPE'}}</text>
            <text class="favorite-pill-text">{{isFavorite ? '已收藏，可继续更新这道菜谱' : '收藏菜谱'}}</text>
          </view>
          <view class="favorite-pill-meta">
            <text class="favorite-pill-icon">{{isFavorite ? '藏' : '收'}}</text>
            <text class="favorite-pill-action">{{isFavorite ? '已保存' : '点我收藏'}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="card utility-card" wx:if="{{isFavorite}}">
      <text class="theme-inline-title">SAVE SETTINGS</text>
      <text class="theme-section-title utility-title">收藏后补充资料</text>

      <view class="utility-row">
        <text class="utility-label">菜谱图片</text>
        <view class="utility-control">
          <view wx:if="{{!(imagePath || recipe.image_full_url)}}" class="camera-btn" bindtap="chooseRecipeImage">
            <text class="camera-btn-icon">上传</text>
          </view>
          <view wx:else class="thumb-wrap">
            <image class="thumb" src="{{imagePath || recipe.image_full_url}}" mode="aspectFill" lazy-load binderror="onRecipeImgError" />
            <view class="remove-thumb" bindtap="removeRecipeImage">删</view>
          </view>
        </view>
      </view>

      <view class="utility-divider"></view>

      <view class="utility-row">
        <text class="utility-label">记录时间</text>
        <view class="utility-control">
          <picker mode="time" value="{{recordTime}}" bindchange="onTimeChange">
            <view class="picker-chip">
              <text class="picker-value">{{recordTime}}</text>
              <text class="picker-arrow">></text>
            </view>
          </picker>
        </view>
      </view>
    </view>

    <view class="card">
      <text class="theme-inline-title">NUTRITION</text>
      <text class="theme-section-title utility-title">营养信息</text>
      <view class="nutrition-grid">
        <view class="nutrition-item">
          <view class="nutrition-value">{{recipe.nutrition.calories}}</view>
          <view class="nutrition-label">热量(千卡)</view>
        </view>
        <view class="nutrition-item">
          <view class="nutrition-value">{{recipe.nutrition.protein}}</view>
          <view class="nutrition-label">蛋白质(g)</view>
        </view>
        <view class="nutrition-item">
          <view class="nutrition-value">{{recipe.nutrition.fat}}</view>
          <view class="nutrition-label">脂肪(g)</view>
        </view>
        <view class="nutrition-item">
          <view class="nutrition-value">{{recipe.nutrition.carbs}}</view>
          <view class="nutrition-label">碳水化合物(g)</view>
        </view>
      </view>
    </view>

    <view class="card">
      <text class="theme-inline-title">INGREDIENTS</text>
      <text class="theme-section-title utility-title">食材清单</text>
      <text class="theme-section-desc">这里可以直接微调用量，营养会按每 100g 或每 100ml 的原始基准重新计算，不做 g 与 ml 互转。</text>

      <view class="ingredients-list">
        <view wx:for="{{recipe.ingredients}}" wx:key="index" class="ingredient-item-card">
          <view class="ingredient-top">
            <view class="ingredient-copy">
              <text class="ingredient-title">{{item.name}}</text>
              <text class="ingredient-basis">{{item.nutritionBasisLabel}}</text>
            </view>
            <view class="ingredient-input-group">
              <input type="number" value="{{item.weight}}" data-index="{{index}}" bindinput="updateIngredientWeight" class="weight-input" />
              <text class="unit-text">{{item.unitNormalized || item.unit || 'g'}}</text>
            </view>
          </view>

          <view class="ingredient-warning" wx:if="{{item.nutritionCalculationBlocked}}">
            当前数量单位与营养基准不一致，这一项已暂停换算，请按原单位编辑。
          </view>

          <view class="ingredient-nutrition-grid">
            <view class="nutrition-cell">
              <view class="nutrition-value-small">{{item.nutritionInfo.calories}}</view>
              <view class="nutrition-label-small">热量</view>
            </view>
            <view class="nutrition-cell">
              <view class="nutrition-value-small">{{item.nutritionInfo.protein}}</view>
              <view class="nutrition-label-small">蛋白质</view>
            </view>
            <view class="nutrition-cell">
              <view class="nutrition-value-small">{{item.nutritionInfo.fat}}</view>
              <view class="nutrition-label-small">脂肪</view>
            </view>
            <view class="nutrition-cell">
              <view class="nutrition-value-small">{{item.nutritionInfo.carbohydrates || item.nutritionInfo.carbs}}</view>
              <view class="nutrition-label-small">碳水</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="card">
      <text class="theme-inline-title">METHOD</text>
      <text class="theme-section-title utility-title">制作步骤</text>
      <view class="steps-list">
        <view wx:for="{{recipe.steps}}" wx:key="index" class="step-item">
          <view class="step-number">{{index + 1}}</view>
          <view class="step-content">{{item}}</view>
        </view>
      </view>
    </view>

    <view class="card" wx:if="{{recipe.tips}}">
      <text class="theme-inline-title">TIPS</text>
      <text class="theme-section-title utility-title">烹饪技巧</text>
      <view class="tips-content">{{recipe.tips}}</view>
    </view>

    <view class="sticky-actions" wx:if="{{isFavorite || isLocalHistoryRecipe}}">
      <button class="btn-secondary sticky-btn sticky-btn-left" bindtap="recordRecipeToDiet">记录到饮食</button>
      <button wx:if="{{isFavorite}}" class="btn-primary sticky-btn sticky-btn-right" bindtap="updateFavoriteRecipe">更新改动</button>
      <button wx:elif="{{isLocalHistoryRecipe}}" class="btn-primary sticky-btn sticky-btn-right" bindtap="saveRecentRecipe">保存</button>
    </view>
  </view>
</view>
