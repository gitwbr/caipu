.recipe-page {
  min-height: 100vh;
}

.recipe-shell {
  padding-bottom: 220rpx;
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
}

.recipe-shell--with-actions {
  padding-bottom: 340rpx;
  padding-bottom: calc(340rpx + env(safe-area-inset-bottom));
}

.recipe-hero {
  padding: 36rpx 28rpx;
  border-radius: 36rpx;
  background: linear-gradient(145deg, #1f3b34 0%, #152621 100%);
  box-shadow: 0 22rpx 48rpx rgba(24, 39, 34, 0.18);
  color: #fff6eb;
  animation: rise-in 0.5s ease both;
}

.recipe-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.recipe-hero-tag {
  margin: 0 10rpx 10rpx 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 244, 230, 0.12);
  color: rgba(255, 244, 230, 0.86);
  font-size: 22rpx;
}

.recipe-toolbar {
  margin-top: 22rpx;
}

.favorite-pill {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 244, 230, 0.12);
}

.favorite-pill-active {
  background: #b85e3a;
}

.favorite-pill-icon {
  margin-right: 10rpx;
  color: #fff6eb;
  font-size: 22rpx;
  font-weight: 700;
}

.favorite-pill-text {
  color: #fff6eb;
  font-size: 24rpx;
  font-weight: 600;
}

.utility-card {
  animation: rise-in 0.58s ease both;
}

.utility-title {
  display: block;
  margin-top: 10rpx;
}

.utility-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 22rpx;
}

.utility-label {
  color: #3e433c;
  font-size: 28rpx;
  font-weight: 600;
}

.utility-control {
  display: flex;
  align-items: center;
}

.utility-divider {
  height: 1rpx;
  margin-top: 22rpx;
  background: rgba(154, 103, 69, 0.08);
}

.camera-btn {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #f4ede5;
}

.camera-btn-icon {
  color: #9b6847;
  font-size: 24rpx;
  font-weight: 700;
}

.thumb-wrap {
  position: relative;
  width: 132rpx;
  height: 132rpx;
  border-radius: 22rpx;
  overflow: hidden;
  background: #f4ede5;
}

.thumb {
  width: 100%;
  height: 100%;
}

.remove-thumb {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  min-width: 40rpx;
  height: 40rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: rgba(184, 94, 58, 0.92);
  color: #fff8f2;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.picker-chip {
  display: flex;
  align-items: center;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: #f4ede5;
}

.picker-value {
  color: #3d423b;
  font-size: 26rpx;
}

.picker-arrow {
  margin-left: 12rpx;
  color: #a2978b;
  font-size: 28rpx;
}

.ingredients-list {
  margin-top: 22rpx;
}

.ingredient-item-card {
  margin-top: 14rpx;
  padding: 22rpx 20rpx;
  border-radius: 26rpx;
  background: #f7efe5;
}

.ingredient-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.ingredient-title {
  color: #21332d;
  font-size: 29rpx;
  font-weight: 700;
}

.ingredient-input-group {
  display: flex;
  align-items: center;
  padding: 10rpx 14rpx;
  border-radius: 16rpx;
  background: #fff;
}

.weight-input {
  width: 96rpx;
  text-align: right;
  color: #1f3b34;
  font-size: 28rpx;
  font-weight: 700;
}

.unit-text {
  margin-left: 8rpx;
  color: #7f7367;
  font-size: 24rpx;
}

.ingredient-nutrition-grid {
  display: flex;
  flex-wrap: wrap;
  margin-top: 18rpx;
  margin-right: -10rpx;
}

.nutrition-cell {
  width: calc(25% - 10rpx);
  margin: 0 10rpx 10rpx 0;
  padding: 16rpx 8rpx;
  border-radius: 18rpx;
  background: #fff;
  text-align: center;
  box-sizing: border-box;
}

.nutrition-value-small {
  color: #243832;
  font-size: 24rpx;
  font-weight: 700;
}

.nutrition-label-small {
  margin-top: 6rpx;
  color: #8d8074;
  font-size: 20rpx;
}

.steps-list {
  margin-top: 22rpx;
}

.tips-content {
  margin-top: 18rpx;
  color: #44423d;
  font-size: 28rpx;
  line-height: 1.7;
}

.sticky-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  padding: 24rpx 24rpx 24rpx;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(248, 244, 238, 0) 0%, rgba(248, 244, 238, 0.92) 36%, #f8f4ee 100%);
  box-sizing: border-box;
  pointer-events: none;
}

.sticky-btn {
  flex: 1;
  margin-right: 12rpx;
  pointer-events: auto;
}

.sticky-btn-right {
  margin-right: 0;
}
