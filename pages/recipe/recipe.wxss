.recipe-page {
  min-height: 100vh;
}

.recipe-shell {
  padding-bottom: 220rpx;
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
}

.recipe-shell--with-actions {
  padding-bottom: 340rpx;
  padding-bottom: calc(340rpx + env(safe-area-inset-bottom));
}

.recipe-hero {
  padding: 36rpx 28rpx;
  border-radius: 36rpx;
  background: linear-gradient(145deg, #1f3b34 0%, #152621 100%);
  box-shadow: 0 22rpx 48rpx rgba(24, 39, 34, 0.18);
  color: #fff6eb;
  animation: rise-in 0.5s ease both;
}

.recipe-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.recipe-hero-tag {
  margin: 0 10rpx 10rpx 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 244, 230, 0.12);
  color: rgba(255, 244, 230, 0.86);
  font-size: 22rpx;
}

.recipe-toolbar {
  margin-top: 28rpx;
}

.favorite-pill {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 22rpx 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #ffe3bf 0%, #f6c37b 52%, #e29a57 100%);
  box-shadow: 0 20rpx 36rpx rgba(10, 14, 12, 0.22), inset 0 1rpx 0 rgba(255, 255, 255, 0.34);
  border: 1rpx solid rgba(255, 246, 235, 0.24);
  box-sizing: border-box;
  overflow: hidden;
  transform: translateY(0);
  transition: transform 180ms ease, box-shadow 180ms ease;
}

.favorite-pill::after {
  content: '';
  position: absolute;
  top: -24rpx;
  right: 26rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 999rpx;
  background: rgba(255, 251, 244, 0.24);
  filter: blur(8rpx);
}

.favorite-pill-active {
  background: linear-gradient(135deg, #e5f0d4 0%, #b8d194 52%, #7c9b61 100%);
  box-shadow: 0 20rpx 36rpx rgba(9, 24, 17, 0.24), inset 0 1rpx 0 rgba(255, 255, 255, 0.28);
}

.favorite-pill-copy {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  flex: 1;
  min-width: 0;
}

.favorite-pill-kicker {
  color: rgba(43, 30, 19, 0.7);
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.favorite-pill-active .favorite-pill-kicker {
  color: rgba(29, 54, 35, 0.7);
}

.favorite-pill-icon {
  color: #2a1a0f;
  font-size: 28rpx;
  font-weight: 700;
}

.favorite-pill-text {
  margin-top: 8rpx;
  color: #2f1d11;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.25;
}

.favorite-pill-active .favorite-pill-text,
.favorite-pill-active .favorite-pill-icon,
.favorite-pill-active .favorite-pill-action {
  color: #1c3624;
}

.favorite-pill-meta {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 132rpx;
  margin-left: 20rpx;
  padding: 14rpx 16rpx;
  border-radius: 22rpx;
  background: rgba(255, 252, 246, 0.42);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
}

.favorite-pill-active .favorite-pill-meta {
  background: rgba(246, 252, 239, 0.42);
}

.favorite-pill-action {
  margin-top: 6rpx;
  color: #4b3320;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.utility-card {
  animation: rise-in 0.58s ease both;
}

.utility-title {
  display: block;
  margin-top: 10rpx;
}

.utility-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 22rpx;
}

.utility-label {
  color: #3e433c;
  font-size: 28rpx;
  font-weight: 600;
}

.utility-control {
  display: flex;
  align-items: center;
}

.utility-divider {
  height: 1rpx;
  margin-top: 22rpx;
  background: rgba(154, 103, 69, 0.08);
}

.camera-btn {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #f4ede5;
}

.camera-btn-icon {
  color: #9b6847;
  font-size: 24rpx;
  font-weight: 700;
}

.thumb-wrap {
  position: relative;
  width: 132rpx;
  height: 132rpx;
  border-radius: 22rpx;
  overflow: hidden;
  background: #f4ede5;
}

.thumb {
  width: 100%;
  height: 100%;
}

.remove-thumb {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  min-width: 40rpx;
  height: 40rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: rgba(184, 94, 58, 0.92);
  color: #fff8f2;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.picker-chip {
  display: flex;
  align-items: center;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: #f4ede5;
}

.picker-value {
  color: #3d423b;
  font-size: 26rpx;
}

.picker-arrow {
  margin-left: 12rpx;
  color: #a2978b;
  font-size: 28rpx;
}

.ingredients-list {
  margin-top: 22rpx;
}

.ingredient-item-card {
  margin-top: 14rpx;
  padding: 22rpx 20rpx;
  border-radius: 26rpx;
  background: #f7efe5;
}

.ingredient-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.ingredient-copy {
  display: flex;
  flex-direction: column;
}

.ingredient-title {
  color: #21332d;
  font-size: 29rpx;
  font-weight: 700;
}

.ingredient-basis {
  margin-top: 8rpx;
  color: #92755f;
  font-size: 22rpx;
}

.ingredient-input-group {
  display: flex;
  align-items: center;
  padding: 10rpx 14rpx;
  border-radius: 16rpx;
  background: #fff;
}

.weight-input {
  width: 96rpx;
  text-align: right;
  color: #1f3b34;
  font-size: 28rpx;
  font-weight: 700;
}

.unit-text {
  margin-left: 8rpx;
  color: #7f7367;
  font-size: 24rpx;
}

.ingredient-warning {
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(184, 94, 58, 0.08);
  color: #a15635;
  font-size: 22rpx;
  line-height: 1.6;
}

.ingredient-nutrition-grid {
  display: flex;
  flex-wrap: wrap;
  margin-top: 18rpx;
  margin-right: -10rpx;
}

.nutrition-cell {
  width: calc(25% - 10rpx);
  margin: 0 10rpx 10rpx 0;
  padding: 16rpx 8rpx;
  border-radius: 18rpx;
  background: #fff;
  text-align: center;
  box-sizing: border-box;
}

.nutrition-value-small {
  color: #243832;
  font-size: 24rpx;
  font-weight: 700;
}

.nutrition-label-small {
  margin-top: 6rpx;
  color: #8d8074;
  font-size: 20rpx;
}

.steps-list {
  margin-top: 22rpx;
}

.tips-content {
  margin-top: 18rpx;
  color: #44423d;
  font-size: 28rpx;
  line-height: 1.7;
}

.sticky-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  padding: 24rpx 24rpx 24rpx;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(248, 244, 238, 0) 0%, rgba(248, 244, 238, 0.92) 36%, #f8f4ee 100%);
  box-sizing: border-box;
  pointer-events: none;
}

.sticky-btn {
  flex: 1;
  margin-right: 12rpx;
  pointer-events: auto;
}

.sticky-btn-right {
  margin-right: 0;
}
