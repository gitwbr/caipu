/* pages/record/quick-record.wxss */
.quick-record-page {
  min-height: 100vh;
}

.quick-record-shell {
  padding-bottom: 220rpx;
}

.quick-form-card {
  animation: rise-in 0.58s ease both;
}

.quick-form-title {
  display: block;
  margin-top: 10rpx;
}

.form-item {
  margin-top: 20rpx;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 20rpx;
}

.form-item.half {
  margin-top: 0;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  color: #5f554d;
  font-size: 26rpx;
  font-weight: 600;
}

.input,
.picker-content,
.textarea {
  width: 100%;
  box-sizing: border-box;
  border-radius: 18rpx;
  background: #f7efe5;
  color: #20332d;
  font-size: 28rpx;
}

.input,
.picker-content {
  min-height: 80rpx;
}

.input {
  padding: 0 20rpx;
}

.picker-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
}

.picker-value {
  color: #20332d;
  font-size: 28rpx;
}

.picker-arrow {
  color: #a79384;
  font-size: 28rpx;
}

.textarea {
  min-height: 140rpx;
  padding: 18rpx 20rpx;
  line-height: 1.6;
}

.section-divider {
  height: 1rpx;
  margin: 26rpx 0 6rpx;
  background: rgba(154, 103, 69, 0.08);
}

.image-inline {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.image-label {
  margin-bottom: 0;
}

.image-inline-slot {
  display: flex;
  align-items: center;
}

.camera-btn-mini {
  width: 90rpx;
  height: 90rpx;
  border-radius: 22rpx;
  background: #f4ede5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #9b6847;
}

.thumb-wrap {
  position: relative;
  width: 144rpx;
  height: 144rpx;
  border-radius: 22rpx;
  overflow: hidden;
  box-shadow: 0 14rpx 24rpx rgba(77, 61, 42, 0.1);
}

.thumb {
  width: 100%;
  height: 100%;
}

.remove-thumb {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 999rpx;
  background: rgba(212, 98, 75, 0.96);
  color: #fff8f2;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.btn {
  flex: 1;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn.loading {
  opacity: 0.78;
}
