/* pages/record/record-detail-list.wxss */
.detail-list-page {
  min-height: 100vh;
}

.custom-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 30;
  padding-top: 44rpx;
  background: rgba(248, 244, 238, 0.88);
  border-bottom: 1rpx solid rgba(154, 103, 69, 0.08);
  backdrop-filter: blur(18rpx);
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
}

.navbar-left,
.navbar-right {
  width: 88rpx;
  display: flex;
  align-items: center;
}

.navbar-right {
  justify-content: flex-end;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.72);
  color: #21342d;
  font-size: 42rpx;
  font-weight: 300;
}

.navbar-center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.date-display {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.date-text {
  color: #2a3f38;
  font-size: 30rpx;
  line-height: 1.1;
  font-weight: 700;
}

.weekday-text {
  margin-top: 6rpx;
  color: #8b7a6d;
  font-size: 20rpx;
  line-height: 1;
}

.calendar-icon {
  margin-left: 10rpx;
  color: #9b6847;
  font-size: 18rpx;
}

.detail-list-shell {
  position: relative;
  z-index: 1;
  padding: 152rpx 24rpx 220rpx;
  box-sizing: border-box;
}

.calendar-overlay {
  position: fixed;
  inset: 0;
  z-index: 40;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  padding: 180rpx 24rpx 24rpx;
  background: rgba(31, 26, 20, 0.24);
  backdrop-filter: blur(8rpx);
  box-sizing: border-box;
}

.calendar-popup {
  width: 100%;
  padding: 30rpx 24rpx;
  border-radius: 30rpx;
  background: #fffdf9;
  box-shadow: 0 20rpx 40rpx rgba(77, 61, 42, 0.14);
  box-sizing: border-box;
}

.calendar-header {
  margin-bottom: 20rpx;
}

.calendar-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.nav-arrow {
  width: 58rpx;
  height: 58rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f4ede5;
  color: #2a3f38;
  font-size: 34rpx;
}

.calendar-title {
  color: #21342d;
  font-size: 30rpx;
  font-weight: 700;
}

.weekdays,
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.weekday {
  text-align: center;
  font-size: 22rpx;
  color: #9b8c80;
  padding: 8rpx 0;
}

.calendar-day {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 78rpx;
  border-radius: 20rpx;
  background: #faf5ee;
}

.day-number {
  font-size: 26rpx;
  color: #34433d;
}

.calendar-day.other-month {
  background: transparent;
}

.calendar-day.other-month .day-number {
  color: #d1c5ba;
}

.calendar-day.selected {
  background: #21443c;
  box-shadow: 0 12rpx 18rpx rgba(33, 68, 60, 0.14);
}

.calendar-day.selected .day-number {
  color: #fff7ef;
  font-weight: 700;
}

.calendar-day.has-record .day-number {
  color: #b85e3a;
  font-weight: 700;
}

.calendar-day.selected.has-record .day-number {
  color: #fff7ef;
}

.record-dot {
  position: absolute;
  bottom: 10rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #d57a4f;
}

.calendar-day.selected .record-dot {
  background: #fff6eb;
}

.summary-card,
.records-section {
  padding: 30rpx 24rpx;
  border-radius: 32rpx;
  background: #fffdf9;
  box-shadow: 0 18rpx 36rpx rgba(77, 61, 42, 0.08);
  box-sizing: border-box;
}

.summary-card-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.summary-head-copy {
  display: flex;
  flex-direction: column;
}

.summary-title {
  margin-top: 10rpx;
  color: #21342d;
  font-size: 34rpx;
  font-weight: 700;
}

.summary-date-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f4ede5;
  color: #9b6847;
  font-size: 22rpx;
  font-weight: 600;
}

.top-summary {
  display: grid;
  grid-template-columns: 1fr 1.8fr 1fr;
  gap: 14rpx;
  margin-top: 26rpx;
  align-items: center;
}

.summary-side-card {
  min-height: 176rpx;
  padding: 22rpx 18rpx;
  border-radius: 26rpx;
  background: #f7efe5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.summary-side-card--warm {
  background: linear-gradient(180deg, #f6eadf 0%, #f1dfcf 100%);
}

.summary-center {
  position: relative;
  min-height: 380rpx;
}

.ring-wrap {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 180px;
  height: 180px;
}

.ring-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  display: block;
  z-index: 1;
}

.ring-text {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 220rpx;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  z-index: 2;
}

.ring-main {
  color: #65584d;
  font-size: 24rpx;
}

.ring-value {
  margin-top: 10rpx;
  color: #d3624b;
  font-size: 46rpx;
  line-height: 1;
  font-weight: 700;
}

.ring-sub {
  margin-top: 8rpx;
  color: #91857a;
  font-size: 21rpx;
  line-height: 1.5;
}

.mini-label {
  color: #857465;
  font-size: 22rpx;
}

.mini-value {
  margin-top: 12rpx;
  color: #20332d;
  font-size: 34rpx;
  font-weight: 700;
}

.mini-unit {
  margin-top: 8rpx;
  color: #9b8c80;
  font-size: 22rpx;
}

.macro-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 20rpx;
}

.macro-col {
  padding: 18rpx 12rpx;
  border-radius: 22rpx;
  background: #f8f2ea;
  text-align: center;
}

.macro-label {
  display: block;
  color: #8d7d6f;
  font-size: 22rpx;
}

.macro-number {
  display: block;
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.macro-number.protein {
  color: #3f8cff;
}

.macro-number.fat {
  color: #e27c4a;
}

.macro-number.carb {
  color: #00a357;
}

.record-buttons {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.record-btn {
  flex: 1;
  padding: 24rpx 20rpx;
  border-radius: 28rpx;
  background: #fffdf9;
  box-shadow: 0 18rpx 36rpx rgba(77, 61, 42, 0.08);
  box-sizing: border-box;
}

.diet-btn {
  background: linear-gradient(180deg, #fffdf9 0%, #f7efe5 100%);
}

.exercise-btn {
  background: linear-gradient(180deg, #fffdf9 0%, #f1e7dd 100%);
}

.btn-icon {
  width: 54rpx;
  height: 54rpx;
  border-radius: 18rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  color: #21443c;
  font-size: 24rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(77, 61, 42, 0.08);
}

.btn-text {
  display: block;
  margin-top: 16rpx;
  color: #20332d;
  font-size: 30rpx;
  font-weight: 700;
}

.btn-note {
  display: block;
  margin-top: 10rpx;
  color: #7b7064;
  font-size: 23rpx;
  line-height: 1.55;
}

.records-section {
  margin-top: 20rpx;
}

.records-section-secondary {
  margin-top: 16rpx;
}

.section-title-copy {
  display: flex;
  flex-direction: column;
}

.section-title-row {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
}

.title-text {
  color: #21342d;
  font-size: 34rpx;
  font-weight: 700;
}

.record-count {
  margin-left: 12rpx;
  color: #9b8c80;
  font-size: 24rpx;
}

.records-list {
  margin-top: 20rpx;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(154, 103, 69, 0.08);
}

.record-item:last-child {
  border-bottom: none;
}

.record-item.highlight {
  margin: 0 -10rpx;
  padding: 18rpx 10rpx;
  border-radius: 20rpx;
  background: rgba(33, 68, 60, 0.06);
}

.record-thumb {
  width: 86rpx;
  height: 86rpx;
  border-radius: 22rpx;
  margin-right: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f6ede2;
}

.record-thumb-exercise {
  background: #f2e7dc;
}

.thumb {
  width: 100%;
  height: 100%;
}

.thumb-placeholder {
  color: #9b6847;
  font-size: 28rpx;
  font-weight: 700;
}

.record-info {
  flex: 1;
  min-width: 0;
}

.food-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.food-name {
  flex: 1;
  min-width: 0;
  color: #21342d;
  font-size: 29rpx;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.record-type-tag {
  flex-shrink: 0;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #f4ede5;
  color: #9b6847;
  font-size: 20rpx;
  font-weight: 600;
}

.record-type-tag.recipe {
  background: #ebf3ef;
  color: #2b6b59;
}

.record-type-tag.quick {
  background: #fbefe4;
  color: #bd6a3c;
}

.record-type-tag.custom {
  background: #f7eff4;
  color: #8c5b76;
}

.record-type-tag.standard {
  background: #efe8de;
  color: #9b6847;
}

.food-details {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 10rpx;
}

.food-quantity,
.food-time {
  color: #85786c;
  font-size: 24rpx;
}

.record-calories {
  margin: 0 12rpx 0 18rpx;
}

.calories-value {
  color: #d3624b;
  font-size: 26rpx;
  font-weight: 700;
  white-space: nowrap;
}

.record-actions {
  display: flex;
  align-items: center;
}

.icon-circle {
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.icon-circle.danger {
  border: 2rpx solid rgba(212, 98, 75, 0.4);
  color: #d3624b;
  background: rgba(212, 98, 75, 0.05);
}

.icon-circle.small {
  width: 40rpx;
  height: 40rpx;
  font-size: 20rpx;
}

.empty-state,
.loading-state {
  margin-top: 18rpx;
  padding: 38rpx 24rpx;
  border-radius: 26rpx;
  background: #faf5ee;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.empty-badge {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  color: #21443c;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 22rpx rgba(77, 61, 42, 0.08);
}

.empty-badge-exercise {
  color: #b85e3a;
}

.empty-text {
  margin-top: 18rpx;
  color: #4d4a44;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-hint,
.loading-text {
  margin-top: 10rpx;
  color: #9b8c80;
  font-size: 24rpx;
  line-height: 1.6;
}
