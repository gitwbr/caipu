.container {
  min-height: 100vh;
  height: auto;
  display: flex;
  flex-direction: column;
  padding: 20rpx 20rpx 28rpx;
  padding: 20rpx 20rpx calc(28rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: linear-gradient(180deg, #f1e5d4 0%, #f6f1ea 260rpx, #f8f4ee 100%);
  font-size: 26rpx;
  overflow: visible;
}

.search-section {
  display: flex;
  align-items: stretch;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.search-box {
  flex: 1;
  min-width: 0;
  height: 84rpx;
  background: #fffdf9;
  border-radius: 24rpx;
  box-shadow: 0 14rpx 28rpx rgba(77, 61, 42, 0.08);
  display: flex;
  align-items: center;
  overflow: hidden;
}

.search-input {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  padding: 0 26rpx;
  color: #30352f;
  font-size: 28rpx;
  background: transparent;
  box-sizing: border-box;
}

.search-btn {
  width: 84rpx;
  min-width: 84rpx;
  height: 84rpx !important;
  line-height: 84rpx;
  padding: 0;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #d57a4f 0%, #b85e3a 100%);
  box-shadow: 0 14rpx 22rpx rgba(184, 94, 58, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.search-btn-text {
  color: #fff8f2;
  font-size: 28rpx;
  font-weight: 700;
}

.action-spotlight {
  margin-bottom: 14rpx;
}

.quick-entry {
  width: 100%;
  min-height: 92rpx;
  padding: 16rpx 20rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, #fdf8f1 0%, #f5ecdf 100%);
  box-shadow: 0 14rpx 26rpx rgba(77, 61, 42, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
  gap: 16rpx;
}

.quick-entry-badge {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #24453d 0%, #376056 100%);
  box-shadow: 0 10rpx 18rpx rgba(36, 69, 61, 0.16);
  flex-shrink: 0;
}

.quick-entry-badge-icon {
  font-size: 24rpx;
  line-height: 1;
}

.quick-entry-badge-text {
  color: #fff8f1;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
}

.quick-entry-copy {
  display: flex;
  align-items: center;
  min-width: 0;
  flex: 1;
}

.quick-entry-desc {
  color: #6c6258;
  font-size: 22rpx;
  line-height: 1.5;
}

.quick-entry-arrow {
  color: #b85e3a;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
  flex-shrink: 0;
}

.main-content {
  display: flex;
  flex: 1;
  min-height: calc(100vh - 248rpx);
  border-radius: 32rpx;
  background: #fffdf9;
  box-shadow: 0 18rpx 36rpx rgba(77, 61, 42, 0.08);
  overflow: hidden;
  align-items: stretch;
}

.sidebar {
  width: 128rpx;
  flex: 0 0 128rpx;
  padding: 20rpx 0;
  background: #f7efe5;
  box-sizing: border-box;
}

.menu-item {
  margin: 0 12rpx 10rpx;
  padding: 20rpx 10rpx;
  border-radius: 22rpx;
  text-align: center;
}

.menu-item.active {
  background: #24453d;
  box-shadow: 0 12rpx 18rpx rgba(36, 69, 61, 0.14);
}

.menu-text {
  display: block;
  color: #72685f;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.45;
  word-break: break-all;
}

.menu-item.active .menu-text {
  color: #fff6eb;
}

.content-area {
  flex: 1;
  min-width: 0;
  padding: 20rpx 18rpx 28rpx;
  box-sizing: border-box;
  overflow-x: hidden;
}

.section-title {
  color: #21342d;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.section-subtitle {
  display: block;
  color: #8d6f57;
  font-size: 22rpx;
  line-height: 1.6;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.add-inline {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.add-hint {
  color: #8d6f57;
  font-size: 22rpx;
}

.custom-hero {
  margin-bottom: 16rpx;
  padding: 16rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fdf8f1 0%, #f6ecdf 100%);
  box-shadow: inset 0 0 0 1rpx rgba(181, 133, 98, 0.12);
}

.custom-hero-copy .section-title {
  margin-bottom: 10rpx;
}

.custom-action-row {
  display: flex;
  flex-direction: row;
  gap: 10rpx;
}

.custom-action-card {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  gap: 10rpx;
  min-height: 0;
  padding: 14rpx 14rpx;
  border-radius: 20rpx;
  box-sizing: border-box;
}

.custom-action-ocr {
  background: linear-gradient(135deg, #24453d 0%, #31584d 100%);
  box-shadow: 0 16rpx 28rpx rgba(36, 69, 61, 0.14);
}

.custom-action-add {
  background: rgba(255, 250, 243, 0.92);
  box-shadow: inset 0 0 0 1rpx rgba(181, 133, 98, 0.16);
}

.custom-action-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 14rpx;
  background: rgba(255, 250, 244, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.custom-action-add .custom-action-icon {
  background: #efe0cf;
  color: #8a5335;
}

.custom-action-copy {
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
  width: 100%;
}

.custom-action-title {
  color: #fff8f1;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
  white-space: nowrap;
}

.custom-action-desc {
  margin-top: 2rpx;
  color: rgba(255, 244, 232, 0.76);
  font-size: 18rpx;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.custom-action-add .custom-action-title {
  color: #24342e;
}

.custom-action-add .custom-action-desc {
  color: #8d6f57;
}

.food-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.food-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  border-radius: 24rpx;
  background: #f7efe5;
  box-sizing: border-box;
}

.food-image {
  width: 82rpx;
  height: 82rpx;
  margin-right: 14rpx;
  border-radius: 20rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
}

.food-thumbnail {
  width: 100%;
  height: 100%;
}

.food-placeholder {
  color: #b28869;
  font-size: 30rpx;
  font-weight: 700;
}

.food-info {
  flex: 1;
  min-width: 0;
}

.food-name {
  color: #24342e;
  font-size: 26rpx;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.food-calories {
  margin-top: 6rpx;
  color: #8d6f57;
  font-size: 22rpx;
}

.food-add {
  margin-left: 12rpx;
  color: #b85e3a;
  font-size: 30rpx;
  font-weight: 700;
}

.food-actions {
  display: flex;
  align-items: center;
  margin-left: auto;
}

.icon-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
}

.icon-circle.success {
  background: #24453d;
  color: #fff7ef;
}

.icon-circle.danger {
  background: #f8ede7;
  color: #b85e3a;
}

.icon-circle.small {
  width: 36rpx;
  height: 36rpx;
  font-size: 20rpx;
}

.empty-state {
  padding: 64rpx 18rpx;
  border-radius: 26rpx;
  background: #f7efe5;
  text-align: center;
}

.empty-text {
  display: block;
  color: #24342e;
  font-size: 28rpx;
  font-weight: 700;
}

.empty-hint {
  display: block;
  margin-top: 12rpx;
  color: #857769;
  font-size: 24rpx;
  line-height: 1.6;
}

.loading {
  padding: 80rpx 0;
  color: #857769;
  text-align: center;
}
