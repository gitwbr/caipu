.record-page {
  min-height: 100vh;
}

.hero-metrics {
  display: flex;
  margin-top: 26rpx;
}

.hero-metric {
  flex: 1;
  margin-right: 12rpx;
  padding: 18rpx 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.08);
}

.hero-metric:last-child {
  margin-right: 0;
}

.hero-metric-label {
  display: block;
  color: rgba(255, 244, 230, 0.66);
  font-size: 22rpx;
}

.hero-metric-value {
  display: block;
  margin-top: 10rpx;
  color: #fff6eb;
  font-size: 30rpx;
  font-weight: 700;
}

.dashboard-card,
.weight-card {
  margin-top: 22rpx;
  padding: 30rpx 24rpx;
  border-radius: 32rpx;
  background: #fffdf9;
  box-shadow: 0 18rpx 36rpx rgba(77, 61, 42, 0.08);
  box-sizing: border-box;
  animation: rise-in 0.55s ease both;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.section-link {
  color: #9b6847;
  font-size: 24rpx;
  margin-left: 20rpx;
}

.summary-strip {
  display: flex;
  margin-top: 26rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #f7efe5;
}

.summary-main {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.summary-main-label {
  color: #816f61;
  font-size: 24rpx;
}

.summary-main-value {
  margin-top: 12rpx;
  color: #1f3b34;
  font-size: 60rpx;
  line-height: 1;
  font-weight: 700;
}

.summary-main-unit {
  margin-top: 8rpx;
  color: #8a7a6e;
  font-size: 24rpx;
}

.summary-side {
  width: 210rpx;
  margin-left: 18rpx;
}

.summary-chip {
  padding: 18rpx 16rpx;
  border-radius: 22rpx;
}

.summary-chip + .summary-chip {
  margin-top: 12rpx;
}

.summary-chip-diet {
  background: #24453d;
}

.summary-chip-exercise {
  background: #b85e3a;
}

.summary-chip-label {
  display: block;
  color: rgba(255, 247, 239, 0.72);
  font-size: 22rpx;
}

.summary-chip-value {
  display: block;
  margin-top: 8rpx;
  color: #fff7ef;
  font-size: 28rpx;
  font-weight: 700;
}

.action-row {
  display: flex;
  margin-top: 20rpx;
}

.action-card {
  flex: 1;
  margin-right: 12rpx;
  padding: 24rpx 20rpx;
  border-radius: 26rpx;
  background: #f5ece2;
}

.action-card:last-child {
  margin-right: 0;
}

.action-card-accent {
  background: #f1e4d8;
}

.action-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 18rpx;
  background: #fff;
  color: #1f3b34;
  font-size: 24rpx;
  font-weight: 700;
}

.action-title {
  display: block;
  margin-top: 16rpx;
  color: #20332d;
  font-size: 30rpx;
  font-weight: 700;
}

.action-desc {
  display: block;
  margin-top: 10rpx;
  color: #786d62;
  font-size: 24rpx;
  line-height: 1.55;
}

.weight-title {
  display: block;
  margin-top: 10rpx;
}

.weight-action {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f4ede5;
  color: #9b6847;
  font-size: 24rpx;
  font-weight: 600;
}

.weight-panel {
  display: flex;
  align-items: center;
  margin-top: 26rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #f7efe5;
}

.weight-item,
.weight-progress {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.weight-label,
.weight-progress-label {
  color: #857466;
  font-size: 24rpx;
}

.weight-value,
.weight-progress-value {
  margin-top: 12rpx;
  color: #1f3b34;
  font-size: 36rpx;
  font-weight: 700;
}

.weight-progress-value {
  color: #b85e3a;
}

.weight-unit,
.weight-progress-unit {
  margin-top: 8rpx;
  color: #8f7f72;
  font-size: 22rpx;
}
