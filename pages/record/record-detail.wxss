/* pages/record/record-detail.wxss */
.record-entry-page {
  min-height: 100vh;
}

.record-entry-shell {
  padding-bottom: 220rpx;
}

.food-card,
.form-card {
  animation: rise-in 0.55s ease both;
}

.food-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 16rpx;
}

.food-header-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.food-name {
  color: #21342d;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.4;
}

.food-type {
  margin-top: 10rpx;
  align-self: flex-start;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f4ede5;
  color: #9b6847;
  font-size: 22rpx;
  font-weight: 600;
}

.edit-icon {
  flex-shrink: 0;
}

.icon-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.icon-circle.primary {
  background: #24453d;
  color: #fff5ea;
}

.food-nutrition {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-top: 22rpx;
}

.nutrition-item {
  padding: 18rpx 14rpx;
  border-radius: 22rpx;
  background: #f7efe5;
  text-align: center;
}

.nutrition-label {
  display: block;
  color: #85786c;
  font-size: 22rpx;
}

.nutrition-value {
  display: block;
  margin-top: 10rpx;
  color: #20332d;
  font-size: 28rpx;
  font-weight: 700;
}

.nutrition-unit {
  display: block;
  margin-top: 6rpx;
  color: #9b8c80;
  font-size: 20rpx;
}

.form-title {
  display: block;
  margin-top: 10rpx;
}

.form-item {
  margin-top: 20rpx;
}

.picker-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 80rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background: #f7efe5;
}

.picker-value {
  color: #20332d;
  font-size: 28rpx;
}

.picker-arrow {
  color: #a79384;
  font-size: 28rpx;
}

.quantity-display {
  padding: 24rpx 20rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, #24453d 0%, #1b322c 100%);
}

.quantity-label {
  display: block;
  color: rgba(255, 244, 230, 0.7);
  font-size: 22rpx;
}

.quantity-main {
  display: flex;
  align-items: baseline;
  margin-top: 12rpx;
}

.quantity-value {
  color: #fff7ef;
  font-size: 48rpx;
  line-height: 1;
  font-weight: 700;
}

.quantity-unit {
  margin-left: 10rpx;
  color: rgba(255, 244, 230, 0.82);
  font-size: 24rpx;
}

.form-textarea-small {
  width: 100%;
  min-height: 88rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  box-sizing: border-box;
  background: #f7efe5;
  color: #20332d;
  font-size: 26rpx;
  line-height: 1.6;
}

.keypad {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-top: 22rpx;
}

.key {
  height: 84rpx;
  border-radius: 24rpx;
  background: #f7efe5;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #20332d;
  font-size: 30rpx;
  font-weight: 700;
}

.key-x {
  grid-column: 4;
  grid-row: 1 / span 3;
  height: auto;
  background: #efe3d7;
  color: #b85e3a;
}

.key-save {
  grid-column: span 2;
  background: linear-gradient(135deg, #d57a4f 0%, #b85e3a 100%);
  color: #fff8f2;
}

.calculation-result {
  margin-top: 22rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #faf5ee;
}

.calc-header {
  margin-bottom: 14rpx;
}

.calc-title {
  color: #8e6647;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
}

.calc-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.calc-item {
  padding: 16rpx 14rpx;
  border-radius: 18rpx;
  background: #fffdf9;
  text-align: center;
}

.calc-label {
  display: block;
  color: #85786c;
  font-size: 22rpx;
}

.calc-value {
  display: block;
  margin-top: 8rpx;
  color: #20332d;
  font-size: 24rpx;
  font-weight: 700;
}

.loading {
  padding: 36rpx 24rpx;
  border-radius: 28rpx;
  background: #fffdf9;
  text-align: center;
  color: #9b8c80;
  font-size: 26rpx;
}

.nutri-mask {
  position: fixed;
  inset: 0;
  z-index: 60;
  display: flex;
  align-items: flex-end;
  background: rgba(31, 26, 20, 0.24);
  backdrop-filter: blur(8rpx);
}

.nutri-sheet {
  width: 100%;
  max-height: 78vh;
  border-radius: 32rpx 32rpx 0 0;
  background: #fffdf9;
  padding: 28rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.nutri-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nutri-title {
  color: #21342d;
  font-size: 32rpx;
  font-weight: 700;
}

.nutri-close {
  width: 52rpx;
  height: 52rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f4ede5;
  color: #9b6847;
  font-size: 28rpx;
}

.nutri-body {
  max-height: 60vh;
  margin-top: 20rpx;
}

.nutri-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.nutri-item {
  padding: 18rpx 16rpx;
  border-radius: 22rpx;
  background: #f7efe5;
}

.nutri-label {
  display: block;
  color: #85786c;
  font-size: 22rpx;
}

.nutri-value {
  display: block;
  margin-top: 8rpx;
  color: #20332d;
  font-size: 26rpx;
  font-weight: 700;
}

.nutri-unit {
  display: block;
  margin-top: 6rpx;
  color: #9b8c80;
  font-size: 20rpx;
}
