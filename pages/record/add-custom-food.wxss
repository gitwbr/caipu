/* pages/record/add-custom-food.wxss */
.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #f1e5d4 0%, #f6f1ea 260rpx, #f8f4ee 100%);
  padding: 0;
  align-items: stretch;
  justify-content: flex-start;
}

/* 页面头部 */
.header { display: none; }

.header-subtitle { display: none; }

.section-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.section-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  gap: 14rpx;
}

.section-hint { color: #9aa0a6; font-size: 24rpx; }
.section-hint-inline { color: #9aa0a6; font-size: 24rpx; }

/* 顶部图标按钮（清空） */
.icon-btn {
  margin: 0;
  min-width: 72rpx;
  height: 72rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #f4ede5;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  box-sizing: border-box;
}

.clear-icon { color: #ff6b6b; }
.section-clear-btn { flex-shrink: 0; }
.clear-text-btn {
  margin: 0;
  min-width: auto;
  height: auto;
  padding: 2rpx 0;
  border: none;
  border-radius: 0;
  background: transparent;
  color: #a16745;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  justify-content: flex-end;
}

.clear-text-btn::after {
  border: none;
}

/* 表单容器 */
.form-container {
  flex: 1;
  padding: 20rpx 24rpx 220rpx;
  box-sizing: border-box;
}

/* 表单区块 */
.form-section {
  background: #fffdf9;
  border-radius: 32rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 18rpx 36rpx rgba(77, 61, 42, 0.08);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #21342d;
  margin-bottom: 24rpx;
  padding-bottom: 14rpx;
  border-bottom: 2rpx solid rgba(154, 103, 69, 0.08);
}

.section-title-plain {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.section-bar .section-title,
.section-bar .section-title-plain {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
  line-height: 1.2;
}

/* 表单行 */
.form-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

/* 表单项 */
.form-item {
  flex: 1;
  margin-bottom: 20rpx;
}

.form-item.half {
  flex: 0 0 calc(50% - 10rpx);
}

/* 标签 */
.label {
  display: block;
  font-size: 28rpx;
  color: #5f554d;
  margin-bottom: 10rpx;
  font-weight: 600;
}

.label.required::after {
  content: ' *';
  color: #ff3b30;
}

/* 输入框 */
.input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: none;
  border-radius: 18rpx;
  font-size: 28rpx;
  background: #f7efe5;
}

/* 图片上传样式 */
.image-section {
  margin-top: 10rpx;
}

/* 行内图片区域 */
.image-inline { display: flex; align-items: center; justify-content: space-between; }
.image-inline .label { margin: 0; }
.camera-slot { display: flex; align-items: center; }
.camera-btn {
  padding: 12rpx 22rpx;
  background: #f4ede5;
  color: #9b6847;
  border: none;
  border-radius: 18rpx;
  font-size: 26rpx;
}
.camera-icon { font-size: 32rpx; line-height: 1; }
.thumb-wrap { position: relative; width: 140rpx; height: 140rpx; border-radius: 22rpx; overflow: hidden; box-shadow: 0 14rpx 24rpx rgba(77,61,42,0.1); }
.thumb { width: 100%; height: 100%; background: #f6f6f6; }
.remove-thumb { position: absolute; top: 8rpx; right: 8rpx; width: 36rpx; height: 36rpx; border-radius: 50%; background: rgba(212,98,75,0.96); color: #fff8f2; font-size: 24rpx; line-height: 36rpx; text-align: center; box-shadow: 0 4rpx 10rpx rgba(212,98,75,0.24); }

.image-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.image-btn {
  flex: 1;
  height: 80rpx;
  background: linear-gradient(135deg, #d57a4f 0%, #b85e3a 100%);
  color: #fff8f2;
  border: none;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 26rpx rgba(184, 94, 58, 0.2);
}

.image-preview {
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.preview-image {
  width: 100%;
  height: 300rpx;
  background-color: #f8f8f8;
}

.image-actions {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  display: flex;
  gap: 10rpx;
}

.action-btn {
  padding: 8rpx 16rpx;
  border: none;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
  min-width: 60rpx;
}

.action-btn.remove {
  background-color: rgba(255, 59, 48, 0.9);
  color: white;
}

.input {
  color: #20332d;
  background-color: #f7efe5;
  box-sizing: border-box;
  transition: border-color 0.3s ease;
}

.input:focus {
  border-color: transparent;
  outline: none;
}

.input::placeholder {
  color: #999;
}

/* 能量输入组件 */
.energy-input-group {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.energy-input {
  flex: 1;
}

.unit-picker {
  flex: 0 0 120rpx;
  height: 80rpx;
  border: none;
  border-radius: 18rpx;
  background-color: #f7efe5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.picker-text {
  font-size: 28rpx;
  color: #20332d;
  font-weight: 600;
}

.unit-hint {
  font-size: 24rpx;
  color: #8f7f72;
  margin-top: 8rpx;
  display: block;
}

.ocr-assist-card {
  margin-top: 20rpx;
  padding: 24rpx 22rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, #fbf4ec 0%, #f7efe5 100%);
  border: 1rpx solid rgba(154, 103, 69, 0.1);
  box-sizing: border-box;
}

.ocr-assist-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.ocr-assist-copy {
  flex: 1;
  min-width: 0;
}

.ocr-assist-kicker {
  display: block;
  color: #a16745;
  font-size: 20rpx;
  letter-spacing: 3rpx;
  font-weight: 700;
}

.ocr-assist-title {
  display: block;
  margin-top: 10rpx;
  color: #21342d;
  font-size: 28rpx;
  font-weight: 700;
}

.ocr-copy-btn {
  margin: 0;
  min-width: auto;
  height: auto;
  padding: 2rpx 0;
  border-radius: 0;
  background: transparent;
  color: #a16745;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
  display: inline-flex;
  align-items: center;
  justify-content: flex-end;
}

.ocr-copy-btn::after {
  border: none;
}

.ocr-copy-btn-secondary {
  background: transparent;
  color: #a16745;
}

.ocr-assist-summary,
.ocr-assist-basis {
  display: block;
  margin-top: 14rpx;
  color: #6d6258;
  font-size: 24rpx;
  line-height: 1.7;
}

.ocr-assist-warning {
  margin-top: 16rpx;
  padding: 18rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(213, 122, 79, 0.1);
}

.ocr-assist-warning-text {
  display: block;
  margin-top: 8rpx;
  color: #8e5338;
  font-size: 23rpx;
  line-height: 1.65;
}

.ocr-assist-warning-text:first-child {
  margin-top: 0;
}

.ocr-assist-detected,
.ocr-assist-raw {
  margin-top: 16rpx;
}

.ocr-raw-section {
  margin-top: 6rpx;
}

.ocr-raw-body {
  margin-top: 18rpx;
}

.ocr-assist-raw-label {
  display: block;
  color: #8f7f72;
  font-size: 22rpx;
  font-weight: 600;
}

.ocr-assist-raw-text {
  display: block;
  margin-top: 10rpx;
  padding: 18rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 253, 249, 0.92);
  color: #4e4a45;
  font-size: 23rpx;
  line-height: 1.7;
  white-space: pre-line;
  box-sizing: border-box;
}

/* 底部操作区 */
.bottom-actions {
  padding: 30rpx;
  background-color: #fffdf9;
  border-top: 1rpx solid rgba(154, 103, 69, 0.08);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #d57a4f 0%, #b85e3a 100%);
  color: #fff8f2;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.submit-btn:active { transform: scale(0.98); }

.submit-btn.loading {
  background: #ccc;
  color: #999;
}

.submit-btn:disabled {
  background: #ccc;
  color: #999;
}

/* 底部间距 */
.bottom-spacing {
  height: 120rpx;
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .form-row {
    flex-direction: column;
    gap: 0;
  }
  
  .form-item.half {
    flex: 1;
  }
}

/* 输入框聚焦效果 */
.input:focus {
  border-color: transparent;
  box-shadow: none;
}

/* 数字输入框特殊样式 */
input[type="number"],
input[type="digit"] {
  text-align: right;
}

/* 表单验证错误状态 */
.input.error {
  border-color: #ff3b30;
  box-shadow: 0 0 0 4rpx rgba(255, 59, 48, 0.1);
}

/* 加载状态 */
.loading {
  opacity: 0.6;
  pointer-events: none;
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.form-section {
  animation: fadeIn 0.3s ease-out;
}

/* 滚动条样式 */
::-webkit-scrollbar {
  width: 6rpx;
}

::-webkit-scrollbar-track {
  background: #f1f1f1;
  border-radius: 3rpx;
}

::-webkit-scrollbar-thumb {
  background: #c1c1c1;
  border-radius: 3rpx;
}

::-webkit-scrollbar-thumb:hover {
  background: #a8a8a8;
} 
