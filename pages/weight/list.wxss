.weight-page {
  min-height: 100vh;
}

.list-card {
  animation: rise-in 0.55s ease both;
}

.list-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.weight-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 104rpx;
  padding: 0 4rpx;
  border-bottom: 1rpx solid rgba(154, 103, 69, 0.08);
}

.weight-row:last-child {
  border-bottom: none;
}

.weight-row-copy {
  display: flex;
  flex-direction: column;
}

.weight-row-date {
  color: #26352f;
  font-size: 28rpx;
  font-weight: 600;
}

.weight-row-time {
  margin-top: 8rpx;
  color: #897c70;
  font-size: 22rpx;
}

.weight-row-value {
  display: flex;
  align-items: baseline;
}

.weight-row-number {
  color: #b85e3a;
  font-size: 36rpx;
  font-weight: 700;
}

.weight-row-unit {
  margin-left: 8rpx;
  color: #8f8276;
  font-size: 22rpx;
}

.list-empty {
  margin-top: 20rpx;
  padding-left: 0;
  padding-right: 0;
  box-shadow: none;
}

.add-btn {
  width: 100%;
  margin-top: 24rpx;
}
