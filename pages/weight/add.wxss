.container {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #f1e5d4 0%, #f6f1ea 260rpx, #f8f4ee 100%);
}

.card {
  background: #fffdf9;
  border-radius: 32rpx;
  padding: 18rpx 24rpx;
  box-shadow: 0 18rpx 36rpx rgba(77, 61, 42, 0.08);
}

.row {
  display: flex;
  align-items: center;
  min-height: 94rpx;
  border-bottom: 1rpx solid rgba(154, 103, 69, 0.08);
}

.row:last-child {
  border-bottom: none;
}

.label {
  flex: 0 0 140rpx;
  color: #3c423c;
  font-size: 28rpx;
  font-weight: 600;
}

.value {
  color: #2a312c;
  font-size: 28rpx;
}

.input {
  flex: 1;
  text-align: right;
  color: #1f3b34;
  font-size: 32rpx;
  font-weight: 700;
}

.unit {
  margin-left: 12rpx;
  color: #8c7f73;
  font-size: 22rpx;
}

.actions {
  display: flex;
  gap: 14rpx;
  margin-top: 24rpx;
}

.btn {
  flex: 1;
  border-radius: 999rpx;
  padding: 20rpx 0;
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 700;
}

.primary {
  background: linear-gradient(135deg, #d57a4f 0%, #b85e3a 100%);
  color: #fff8f2;
}

.danger {
  background: #24453d;
  color: #fff7ef;
}
