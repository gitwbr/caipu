.help-page {
  min-height: 100vh;
}

.help-hero {
  animation: rise-in 0.45s ease both;
}

.help-hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 26rpx;
}

.help-section-title {
  display: block;
  margin-top: 12rpx;
}

.faq-list {
  margin-top: 22rpx;
}

.faq-card {
  margin-top: 16rpx;
  padding: 24rpx 22rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, #fbf4ec 0%, #fffdf9 100%);
  border: 1rpx solid rgba(154, 103, 69, 0.08);
  box-sizing: border-box;
}

.faq-card:first-child {
  margin-top: 0;
}

.faq-title {
  display: block;
  color: #21342d;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.45;
}

.faq-desc {
  display: block;
  margin-top: 10rpx;
  color: #766a5e;
  font-size: 24rpx;
  line-height: 1.7;
}

.feedback-step {
  display: flex;
  align-items: flex-start;
  margin-top: 18rpx;
}

.feedback-step:first-of-type {
  margin-top: 24rpx;
}

.feedback-index {
  width: 46rpx;
  height: 46rpx;
  margin-right: 16rpx;
  border-radius: 16rpx;
  background: #24453d;
  color: #fff7ef;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 46rpx;
  text-align: center;
  flex-shrink: 0;
}

.feedback-text {
  flex: 1;
  color: #5e564e;
  font-size: 25rpx;
  line-height: 1.7;
}

.feedback-template-card {
  margin-bottom: 24rpx;
}

.template-box {
  margin-top: 22rpx;
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: #f7efe5;
  box-sizing: border-box;
}

.template-text {
  display: block;
  color: #5f564e;
  font-size: 24rpx;
  line-height: 1.75;
  white-space: pre-line;
}

.template-btn {
  width: 100%;
  margin-top: 24rpx;
}
