.profile-page {
  min-height: 100vh;
}

.profile-hero {
  padding: 36rpx 28rpx;
  border-radius: 36rpx;
  background: linear-gradient(145deg, #1f3b34 0%, #152621 100%);
  box-shadow: 0 22rpx 48rpx rgba(24, 39, 34, 0.18);
  color: #fff6eb;
  animation: rise-in 0.5s ease both;
}

.profile-top {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}

.profile-avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  margin-right: 18rpx;
  border: 4rpx solid rgba(255, 244, 230, 0.18);
}

.profile-copy {
  flex: 1;
  min-width: 0;
}

.profile-name {
  display: block;
  color: #fff7ef;
  font-size: 36rpx;
  font-weight: 700;
}

.profile-sub {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 244, 230, 0.74);
  font-size: 24rpx;
  line-height: 1.5;
}

.profile-edit-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 244, 230, 0.12);
  color: #fff4e5;
  font-size: 22rpx;
  font-weight: 600;
}

.profile-metrics {
  display: flex;
  margin-top: 28rpx;
}

.profile-metric {
  flex: 1;
  margin-right: 12rpx;
  padding: 18rpx 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.08);
}

.profile-metric:last-child {
  margin-right: 0;
}

.profile-metric-label {
  display: block;
  color: rgba(255, 244, 230, 0.66);
  font-size: 22rpx;
}

.profile-metric-value {
  display: block;
  margin-top: 10rpx;
  color: #fff6eb;
  font-size: 30rpx;
  font-weight: 700;
}

.profile-unit {
  margin-left: 6rpx;
  font-size: 20rpx;
  color: rgba(255, 244, 230, 0.72);
}

.grid-cards {
  display: flex;
  gap: 12rpx;
  margin-top: 22rpx;
}

.grid-card {
  position: relative;
  flex: 1;
  min-height: 240rpx;
  padding: 18rpx;
  border-radius: 30rpx;
  overflow: hidden;
  box-shadow: 0 18rpx 36rpx rgba(77, 61, 42, 0.1);
}

.grid-card-mint {
  background: linear-gradient(145deg, #d8eadf 0%, #c3dfcd 100%);
}

.grid-card-gold {
  background: linear-gradient(145deg, #f3e1aa 0%, #e0c477 100%);
}

.grid-card-hover {
  opacity: 0.94;
}

.grid-bg {
  position: absolute;
  right: -6rpx;
  bottom: 18rpx;
  width: 78%;
  height: 78%;
  opacity: 0.3;
}

.grid-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.08) 0%, rgba(26, 26, 26, 0.14) 100%);
}

.grid-content {
  position: relative;
  z-index: 1;
  min-height: 204rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.grid-topline {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.grid-kicker {
  color: rgba(255, 250, 244, 0.82);
  font-size: 20rpx;
  letter-spacing: 3rpx;
}

.grid-chip {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 244, 0.45);
  color: #5d564f;
  font-size: 20rpx;
  font-weight: 600;
}

.grid-footer {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 12rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 251, 246, 0.82);
  box-shadow: 0 10rpx 22rpx rgba(82, 64, 43, 0.08);
}

.grid-copy {
  flex: 1;
  min-width: 0;
}

.grid-title {
  display: block;
  color: #233630;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.2;
}

.grid-desc {
  display: block;
  margin-top: 8rpx;
  color: #726355;
  font-size: 22rpx;
  line-height: 1.5;
}

.grid-arrow {
  flex-shrink: 0;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: rgba(31, 59, 52, 0.08);
  color: #1f3b34;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 42rpx;
  text-align: center;
}

.menu-card {
  margin-top: 22rpx;
  padding: 30rpx 24rpx;
  border-radius: 32rpx;
  background: #fffdf9;
  box-shadow: 0 18rpx 36rpx rgba(77, 61, 42, 0.08);
}

.tool-card {
  margin-top: 18rpx;
}

.menu-title {
  display: block;
  margin-top: 10rpx;
}

.menu-list {
  margin-top: 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  min-height: 84rpx;
  padding: 0 6rpx;
  border-bottom: 1rpx solid rgba(154, 103, 69, 0.08);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 30rpx;
  height: 30rpx;
  margin-right: 16rpx;
}

.menu-text {
  flex: 1;
  color: #3f433d;
  font-size: 27rpx;
}

.menu-arrow {
  color: #ab9f92;
  font-size: 30rpx;
}
