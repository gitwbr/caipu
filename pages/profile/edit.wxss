.edit-page {
  min-height: 100vh;
}

.edit-hero {
  animation: rise-in 0.5s ease both;
}

.avatar-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 34rpx;
  padding-bottom: 34rpx;
  background:
    radial-gradient(circle at 50% 10%, rgba(230, 196, 157, 0.22) 0, rgba(230, 196, 157, 0) 52%),
    linear-gradient(180deg, #fffdf9 0%, #f9f2e9 100%);
}

.avatar-frame {
  position: relative;
  width: 196rpx;
  height: 196rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-frame::before {
  content: '';
  position: absolute;
  inset: 10rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, rgba(31, 59, 52, 0.16) 0%, rgba(198, 122, 79, 0.24) 100%);
}

.edit-avatar {
  position: relative;
  z-index: 1;
  width: 176rpx;
  height: 176rpx;
  border-radius: 50%;
  border: 6rpx solid #fff7ef;
  box-shadow: 0 18rpx 36rpx rgba(77, 61, 42, 0.14);
}

.avatar-badge {
  position: absolute;
  right: 8rpx;
  bottom: 10rpx;
  z-index: 2;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #1f3b34;
  color: #fff6eb;
  font-size: 20rpx;
  letter-spacing: 2rpx;
}

.avatar-copy {
  margin-top: 18rpx;
  text-align: center;
}

.avatar-title {
  display: block;
  color: #25342f;
  font-size: 30rpx;
  font-weight: 700;
}

.avatar-tip {
  display: block;
  margin-top: 10rpx;
  color: #7b7065;
  font-size: 24rpx;
  line-height: 1.6;
}

.form-card {
  animation: rise-in 0.55s ease both;
}

.form-title {
  display: block;
  margin-top: 10rpx;
}

.field-stack {
  margin-top: 22rpx;
}

.form-field {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, #fcf8f2 0%, #f8efe4 100%);
  border: 1rpx solid rgba(154, 103, 69, 0.08);
}

.form-field:first-child {
  margin-top: 0;
}

.form-field-last {
  margin-bottom: 0;
}

.field-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 8rpx 14rpx;
  margin-bottom: 16rpx;
}

.form-label {
  color: #30352f;
  font-size: 29rpx;
  font-weight: 700;
}

.field-note {
  color: #a27f67;
  font-size: 22rpx;
  letter-spacing: 1rpx;
}

.input-shell,
.form-picker {
  display: flex;
  align-items: center;
  min-height: 94rpx;
  padding: 0 22rpx;
  border-radius: 22rpx;
  background: #fffdf9;
  border: 2rpx solid rgba(154, 103, 69, 0.12);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.7);
  box-sizing: border-box;
}

.form-input {
  flex: 1;
  min-width: 0;
  height: 94rpx;
  min-height: 94rpx;
  line-height: 94rpx;
  padding: 0;
  color: #202824;
  font-size: 30rpx;
  box-sizing: border-box;
}

.field-unit {
  flex-shrink: 0;
  margin-left: 16rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f0e3d3;
  color: #9a6745;
  font-size: 22rpx;
  font-weight: 600;
}

.form-picker {
  justify-content: space-between;
}

.picker-text {
  flex: 1;
  min-width: 0;
  color: #30352f;
  font-size: 30rpx;
  line-height: 1.4;
}

.picker-arrow {
  flex-shrink: 0;
  margin-left: 16rpx;
  color: #aa9d91;
  font-size: 30rpx;
}

.save-wrap {
  margin-top: 24rpx;
}

.save-btn {
  width: 100%;
}

.save-tip {
  display: block;
  margin-top: 16rpx;
  color: #8d7a6a;
  font-size: 22rpx;
  line-height: 1.6;
  text-align: center;
}
