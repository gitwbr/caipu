.about-page {
  min-height: 100vh;
}

.about-hero {
  animation: rise-in 0.45s ease both;
}

.about-hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.about-version-pill {
  min-width: 176rpx;
  padding: 16rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 244, 230, 0.12);
  box-sizing: border-box;
}

.about-version-label {
  display: block;
  color: rgba(255, 244, 230, 0.68);
  font-size: 20rpx;
  letter-spacing: 2rpx;
}

.about-version-value {
  display: block;
  margin-top: 8rpx;
  color: #fff7ef;
  font-size: 30rpx;
  font-weight: 700;
}

.about-section-title {
  display: block;
  margin-top: 12rpx;
}

.feature-list {
  margin-top: 22rpx;
}

.feature-card {
  margin-top: 16rpx;
  padding: 24rpx 22rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, #fffdf9 0%, #f8f0e7 100%);
  border: 1rpx solid rgba(154, 103, 69, 0.08);
  box-sizing: border-box;
}

.feature-card:first-child {
  margin-top: 0;
}

.feature-title {
  display: block;
  color: #1f302a;
  font-size: 28rpx;
  font-weight: 700;
}

.feature-desc {
  display: block;
  margin-top: 10rpx;
  color: #786d61;
  font-size: 24rpx;
  line-height: 1.7;
}

.fact-row {
  display: flex;
  align-items: flex-start;
  margin-top: 18rpx;
}

.fact-row:first-of-type {
  margin-top: 24rpx;
}

.fact-mark {
  width: 14rpx;
  height: 14rpx;
  margin: 14rpx 16rpx 0 0;
  border-radius: 50%;
  background: #d57a4f;
  flex-shrink: 0;
}

.fact-text {
  flex: 1;
  color: #60574e;
  font-size: 25rpx;
  line-height: 1.75;
}

.version-card {
  margin-bottom: 24rpx;
}

.version-box {
  margin-top: 22rpx;
  padding: 26rpx 24rpx;
  border-radius: 26rpx;
  background: #f7efe5;
  box-sizing: border-box;
}

.version-box-label {
  display: block;
  color: #a16745;
  font-size: 22rpx;
  letter-spacing: 3rpx;
}

.version-box-value {
  display: block;
  margin-top: 12rpx;
  color: #1f302a;
  font-size: 34rpx;
  font-weight: 700;
}
