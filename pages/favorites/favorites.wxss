.library-page {
  min-height: 100vh;
}

.library-hero {
  animation: rise-in 0.5s ease both;
}

.hero-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-top: 12rpx;
}

.hero-copy {
  flex: 1;
  padding-right: 24rpx;
}

.hero-foot {
  margin-top: 24rpx;
}

.library-switch {
  display: flex;
  gap: 12rpx;
  margin-top: 22rpx;
  padding: 12rpx;
  border-radius: 30rpx;
  background: rgba(255, 253, 249, 0.92);
  box-shadow: 0 14rpx 28rpx rgba(77, 61, 42, 0.08);
  box-sizing: border-box;
}

.library-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 18rpx 18rpx;
  border-radius: 24rpx;
  background: transparent;
}

.library-tab-active {
  background: #f4ede5;
}

.library-tab-text {
  color: #64594f;
  font-size: 26rpx;
  font-weight: 700;
}

.library-tab-count {
  min-width: 52rpx;
  height: 52rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(154, 103, 69, 0.08);
  color: #a16745;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.library-tab-active .library-tab-text {
  color: #1f3b34;
}

.library-tab-active .library-tab-count {
  background: #24453d;
  color: #fff6eb;
}

.recipes-list {
  margin-top: 22rpx;
}

.recipe-card {
  display: flex;
  align-items: flex-start;
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 32rpx;
  background: #fffdf9;
  box-shadow: 0 18rpx 36rpx rgba(77, 61, 42, 0.08);
  box-sizing: border-box;
  animation: rise-in 0.55s ease both;
}

.recipe-index {
  width: 70rpx;
  height: 70rpx;
  margin-right: 18rpx;
  border-radius: 22rpx;
  background: #f7efe5;
  color: #315148;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.recipe-index-favorite {
  background: #efe0cf;
  color: #b45d39;
}

.recipe-main {
  flex: 1;
  min-width: 0;
}

.recipe-top {
  display: flex;
  align-items: center;
}

.recipe-thumb {
  width: 176rpx;
  height: 132rpx;
  border-radius: 22rpx;
  background: #f5ece2;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.thumb {
  width: 100%;
  height: 100%;
}

.thumb-placeholder {
  color: #b18668;
  font-size: 28rpx;
  font-weight: 700;
}

.recipe-copy {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
}

.recipe-title-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.recipe-name {
  display: block;
  color: #1f302a;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.35;
}

.recipe-badge,
.recipe-secondary-badge {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.recipe-badge {
  background: #f4ede5;
  color: #9c6847;
}

.recipe-badge-favorite,
.recipe-secondary-badge {
  background: #fff1e6;
  color: #b35f3a;
}

.recipe-meta-row {
  margin-top: 10rpx;
}

.recipe-desc {
  display: block;
  margin-top: 10rpx;
  color: #756a5f;
  font-size: 24rpx;
  line-height: 1.6;
}

.recipe-bottom {
  margin-top: 18rpx;
}

.calorie-badge {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  background: #f4ede5;
}

.calorie-kicker {
  color: #9c6847;
  font-size: 22rpx;
  margin-right: 10rpx;
}

.calorie-value {
  color: #b65e39;
  font-size: 24rpx;
  font-weight: 700;
}

.recipe-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 14rpx;
}

.recipe-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.recipe-action-delete {
  min-width: 70rpx;
  height: 54rpx;
  padding: 0 14rpx;
  border-radius: 18rpx;
  background: #f8ede7;
  color: #b85e3a;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 22rpx;
  font-weight: 700;
}

.recipe-arrow {
  margin-top: 22rpx;
  color: #a29485;
  font-size: 30rpx;
}

.empty-button {
  width: 100%;
  margin-top: 28rpx;
}
