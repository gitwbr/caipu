.favorites-page {
  min-height: 100vh;
}

.hero-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-top: 12rpx;
}

.hero-copy {
  flex: 1;
  padding-right: 24rpx;
}

.hero-foot {
  margin-top: 24rpx;
}

.favorites-list {
  margin-top: 22rpx;
}

.favorite-card {
  display: flex;
  align-items: flex-start;
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 32rpx;
  background: #fffdf9;
  box-shadow: 0 18rpx 36rpx rgba(77, 61, 42, 0.08);
  box-sizing: border-box;
  animation: rise-in 0.55s ease both;
}

.favorite-index {
  width: 70rpx;
  height: 70rpx;
  margin-right: 18rpx;
  border-radius: 22rpx;
  background: #f7efe5;
  color: #315148;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.favorite-main {
  flex: 1;
  min-width: 0;
}

.favorite-top {
  display: flex;
  align-items: center;
}

.record-thumb {
  width: 176rpx;
  height: 132rpx;
  border-radius: 22rpx;
  background: #f5ece2;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.thumb {
  width: 100%;
  height: 100%;
}

.thumb-placeholder {
  color: #b18668;
  font-size: 32rpx;
  font-weight: 700;
}

.favorite-copy {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
}

.favorite-name {
  display: block;
  color: #1f302a;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.35;
}

.favorite-desc {
  display: block;
  margin-top: 10rpx;
  color: #756a5f;
  font-size: 24rpx;
  line-height: 1.6;
}

.favorite-bottom {
  margin-top: 18rpx;
}

.calorie-badge {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  background: #f4ede5;
}

.calorie-kicker {
  color: #9c6847;
  font-size: 22rpx;
  margin-right: 10rpx;
}

.calorie-value {
  color: #b65e39;
  font-size: 24rpx;
  font-weight: 700;
}

.favorite-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 14rpx;
}

.favorite-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.favorite-delete {
  width: 54rpx;
  height: 54rpx;
  border-radius: 18rpx;
  background: #f8ede7;
  color: #b85e3a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

.favorite-arrow {
  margin-top: 22rpx;
  color: #a29485;
  font-size: 30rpx;
}

.empty-button {
  width: 100%;
  margin-top: 28rpx;
}
