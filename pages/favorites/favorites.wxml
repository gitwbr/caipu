<view class="theme-page favorites-page">
  <view class="theme-ambient theme-ambient--top"></view>
  <view class="theme-ambient theme-ambient--side"></view>

  <view class="theme-shell theme-shell--tab">
    <view class="theme-hero-card">
      <text class="theme-kicker">RECIPE CABINET</text>
      <view class="hero-row">
        <view class="hero-copy">
          <text class="theme-hero-title">我的收藏</text>
          <text class="theme-hero-desc">把想反复做的菜谱留在这里，回头做饭时就不用再翻历史。</text>
        </view>
        <view class="theme-count-badge">{{isLoggedIn ? favorites.length : 'GUEST'}}</view>
      </view>
      <view class="hero-foot">
        <view class="theme-status-pill" wx:if="{{isLoggedIn}}">已登录，可同步管理收藏</view>
        <view class="theme-status-pill" wx:else>登录后可查看并同步收藏</view>
      </view>
    </view>

    <view class="theme-loading" wx:if="{{isLoading}}">
      <view class="theme-loading-icon"></view>
      <text class="theme-loading-text">正在整理你的收藏菜谱...</text>
    </view>

    <view class="favorites-list" wx:if="{{favorites.length > 0 && !isLoading}}">
      <block wx:for="{{favorites}}" wx:key="favoriteId">
        <view class="favorite-card" bindtap="viewRecipe" data-recipe="{{item}}">
          <view class="favorite-index">0{{index + 1}}</view>

          <view class="favorite-main">
            <view class="favorite-top">
              <view class="record-thumb">
                <image wx:if="{{item.image_full_url}}" class="thumb" src="{{item.image_full_url}}" mode="aspectFill" lazy-load binderror="onThumbError" data-index="{{index}}" data-url="{{item.image_full_url}}" />
                <text wx:else class="thumb-placeholder">锅</text>
              </view>

              <view class="favorite-copy">
                <text class="favorite-name">{{item.name}}</text>
                <text class="favorite-desc">{{item.description}}</text>
              </view>
            </view>

            <view class="favorite-bottom">
              <view class="calorie-badge">
                <text class="calorie-kicker">热量</text>
                <text class="calorie-value">{{item.calorie_display}}</text>
              </view>

              <view class="favorite-tags">
                <view class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="idx">{{tag}}</view>
              </view>
            </view>
          </view>

          <view class="favorite-actions">
            <view class="favorite-delete" catchtap="removeFavorite" data-id="{{item.favoriteId}}">删</view>
            <text class="favorite-arrow">></text>
          </view>
        </view>
      </block>
    </view>

    <view class="empty-state" wx:if="{{favorites.length === 0 && !isLoading && isLoggedIn}}">
      <view class="empty-icon">藏</view>
      <text class="empty-title">还没有收藏的菜谱</text>
      <text class="empty-desc">去首页生成几道顺手又想复做的菜，把它们慢慢收进你的厨房柜子里。</text>
      <button class="btn-primary empty-button" bindtap="goToHome">去生成菜谱</button>
    </view>

    <view class="empty-state" wx:if="{{!isLoggedIn && !isLoading}}">
      <view class="empty-icon">登录</view>
      <text class="empty-title">登录后才能查看收藏</text>
      <text class="empty-desc">同步你的收藏菜谱、历史记录和个人偏好，换设备也不会丢。</text>
      <button class="btn-primary empty-button" bindtap="showLoginModal">微信一键登录</button>
    </view>
  </view>
</view>
